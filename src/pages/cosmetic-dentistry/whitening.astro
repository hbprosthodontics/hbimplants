---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'How long does professional teeth whitening last?', answer: 'In-office whitening results typically last 6 months to 2 years depending on your diet and habits. Coffee, tea, red wine, and tobacco are the primary culprits for staining. Take-home trays can be used for touch-up treatments, extending your results indefinitely with minimal effort.' },
  { question: 'Is professional whitening better than over-the-counter whitening?', answer: 'Yes, significantly. Professional whitening uses higher-concentration peroxide gels that penetrate deeper into enamel and produce faster, more dramatic results. Custom-fitted trays ensure the gel contacts every tooth surface evenly without irritating gums. Over-the-counter strips are one-size-fits-all and use lower concentrations — they produce modest results at best.' },
  { question: 'Will whitening work on my crowns or veneers?', answer: 'Whitening does not change the color of porcelain crowns, veneers, bonding, or other dental restorations — only natural tooth enamel responds to whitening agents. If you have visible restorations in your smile zone, whitening should be coordinated with any plans to replace those restorations, so everything can be shade-matched to your new brighter baseline.' },
  { question: 'Is teeth whitening safe?', answer: 'Professional teeth whitening under dental supervision is very safe. The most common side effect is temporary tooth sensitivity during and shortly after treatment, which resolves within 24–48 hours. We recommend whitening to patients with healthy enamel and no active decay or gum disease. Patients with existing sensitivity may need a modified protocol.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Teeth Whitening Huntington Beach | Professional In-Office"
  description="Professional teeth whitening in Huntington Beach, CA. In-office and take-home options for dramatically whiter teeth. Ask about whitening during your consultation."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Professional Teeth Whitening Huntington Beach —<br />
          <span class="text-brand-teal">Long-Lasting Results from a Dental Specialist</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">Professional whitening delivers dramatically brighter results than over-the-counter products — and because it's supervised by a dentist, it's done safely and precisely.</p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Whitening Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="section-heading mb-6">In-Office vs. Take-Home Whitening</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="card border-brand-blue border-2">
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">In-Office Whitening</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Professional-strength gel applied chairside with custom protection for your gums. Results visible in one 60–90 minute appointment. Best for patients who want immediate results before an event or as a starting point for comprehensive cosmetic treatment.</p>
          <ul class="space-y-1 text-sm text-neutral-mid">
            <li>✓ Results same day</li>
            <li>✓ 6–8 shades brighter typical</li>
            <li>✓ Dentist-supervised safety</li>
          </ul>
        </div>
        <div class="card">
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">Take-Home Whitening</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-3">Custom-fitted trays made from impressions of your teeth ensure the whitening gel contacts every surface evenly. Worn 30–60 minutes daily for 2–3 weeks for full results. Best for patients who prefer gradual whitening and want trays for touch-ups.</p>
          <ul class="space-y-1 text-sm text-neutral-mid">
            <li>✓ Custom trays for perfect fit</li>
            <li>✓ Reusable for maintenance</li>
            <li>✓ Gentle and flexible schedule</li>
          </ul>
        </div>
      </div>
      <p class="text-neutral-mid leading-relaxed mb-6">Many patients combine both: in-office whitening for a quick jump-start followed by take-home trays for ongoing maintenance. Whitening is frequently the first step in a <a href="/veneers/smile-makeover" class="text-brand-blue hover:underline">smile makeover</a>, establishing the baseline shade for any <a href="/veneers" class="text-brand-blue hover:underline">veneers</a> or restorations to be matched to. If you're exploring <a href="/cosmetic-dentistry" class="text-brand-blue hover:underline">cosmetic dentistry</a> options, whitening is usually the least invasive place to start.</p>
      <a href="/schedule" class="btn-primary">Ask About Whitening at Your Consultation</a>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Teeth Whitening FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
