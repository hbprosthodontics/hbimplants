---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import FAQBlock from '../components/FAQBlock.astro';

const faqs = [
  {
    question: 'Does dental insurance cover dental implants?',
    answer: 'Many PPO dental plans include partial implant coverage — typically a fixed dollar amount per implant (often $1,000–$1,500) if the plan includes implant benefits. Some older plans exclude implants entirely. The best way to know exactly what your plan covers is to bring your insurance card to your consultation — we verify your benefits and explain your coverage before any treatment begins.',
  },
  {
    question: 'Does insurance cover veneers?',
    answer: 'Standard porcelain veneers are classified as cosmetic by most insurance plans and are not covered. However, if a veneer is the appropriate restorative treatment for a structurally compromised tooth (a cracked tooth, for example), partial coverage may apply under the restorative portion of your plan. We review this at your consultation.',
  },
  {
    question: 'What if I have no dental insurance?',
    answer: 'No insurance is not a barrier to care. Many patients without insurance finance treatment through CareCredit or Proceed Finance, which offer low- or no-interest payment plans. We also offer flexible in-office payment arrangements. The complimentary consultation gives you a clear total cost estimate so you can plan before committing.',
  },
  {
    question: 'How does CareCredit work?',
    answer: 'CareCredit is a healthcare credit card accepted at dental offices nationwide. Once approved, you can use it to pay for treatment and repay over time — often with 0% promotional interest periods of 6, 12, 18, or 24 months depending on the amount. Applying takes a few minutes online or in our office, and approval decisions are typically instant.',
  },
  {
    question: 'Can I split the cost of treatment across multiple appointments?',
    answer: 'In many cases, yes — particularly for multi-phase treatments like dental implants, where the surgical and restorative phases are naturally separated. We discuss payment timing and options at your consultation so you know exactly when each payment is due and can plan accordingly.',
  },
  {
    question: 'Is the consultation really free?',
    answer: 'Yes. The initial consultation for implant and cosmetic cases is complimentary — it includes a clinical examination, a review of your existing records or imaging, and an honest discussion of your options, timeline, and total cost. There is no charge and no obligation to proceed.',
  },
];

import { localBusinessSchema as localBusiness } from '../config/site';
---

<BaseLayout
  title="Financing & Insurance | Huntington Beach Prosthodontics"
  description="Learn how to pay for dental implants, veneers, and prosthodontic care in Huntington Beach. We accept most PPO insurance and offer CareCredit financing."
  schema={localBusiness}
>

  <!-- Hero -->
  <section class="bg-brand-navy py-16 md:py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-3">Financing & Insurance</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Quality dental care should be<br />
          <span class="text-brand-gold">within reach.</span>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          We work with most major PPO dental insurance plans and offer flexible financing through CareCredit and Proceed Finance — so cost doesn't stand between you and the treatment you need.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/dental-implants/consultation" class="btn-accent text-base px-6 py-3 text-center">Free Consultation</a>
          <a href="tel:7148461386" class="border border-white/40 text-white rounded-lg px-6 py-3 text-base font-medium hover:bg-white/10 transition-colors text-center">(714) 846-1386</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Insurance Overview -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Insurance</div>
          <h2 class="section-heading mb-6">We work with your insurance</h2>
          <p class="text-neutral-mid leading-relaxed mb-4">
            We accept most major PPO dental insurance plans and will file claims on your behalf for out-of-network plans. Our team verifies your benefits before treatment begins — so you know exactly what's covered and what your out-of-pocket cost will be, with no surprises.
          </p>
          <p class="text-neutral-mid leading-relaxed mb-8">
            We do not accept HMO or Denti-Cal plans. If you're unsure whether your plan is accepted, call us and we'll check before you come in.
          </p>

          <div class="space-y-4">
            {[
              {
                title: 'PPO Dental Insurance',
                desc: 'Most PPO plans provide benefits for exams, X-rays, cleanings, fillings, extractions, crowns, and sometimes implants. We verify your specific coverage and apply your benefits to your treatment cost.',
                covered: true,
              },
              {
                title: 'Out-of-Network PPO',
                desc: "If we're not in your plan's network, we can still file claims on your behalf. You may have higher out-of-pocket costs, but many patients find the specialist quality worth the difference.",
                covered: true,
              },
              {
                title: 'HMO / Capitation Plans',
                desc: 'HMO dental plans assign you to a network dentist and do not cover out-of-network care. We do not participate in HMO plans.',
                covered: false,
              },
            ].map((item) => (
              <div class={`flex gap-4 p-5 rounded-xl border ${item.covered ? 'border-green-200 bg-green-50' : 'border-neutral-border bg-surface-2'}`}>
                <div class={`w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5 ${item.covered ? 'bg-green-500' : 'bg-neutral-300'}`}>
                  {item.covered
                    ? <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                    : <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
                  }
                </div>
                <div>
                  <div class="font-semibold text-brand-navy text-sm mb-1">{item.title}</div>
                  <div class="text-neutral-mid text-sm leading-relaxed">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">What's Typically Covered</div>
          <h2 class="section-heading mb-6">Understanding your benefits</h2>
          <p class="text-neutral-mid leading-relaxed mb-6">
            Dental insurance is designed primarily for preventive and basic restorative care. Major procedures like implants and cosmetic treatments have more limited coverage. Here's a general guide — your specific plan will differ.
          </p>

          <div class="space-y-3">
            {[
              { procedure: 'Exams & X-rays', coverage: '100%', note: 'Usually fully covered, 1–2x per year' },
              { procedure: 'Cleanings (prophylaxis)', coverage: '100%', note: '2x per year under most plans' },
              { procedure: 'Fillings', coverage: '70–80%', note: 'After deductible' },
              { procedure: 'Crowns', coverage: '50%', note: 'Up to annual maximum, after waiting period' },
              { procedure: 'Dental Implants', coverage: '0–50%', note: 'Varies widely — some plans include $1,000–1,500/implant' },
              { procedure: 'Bone Grafting', coverage: '0–50%', note: 'May be covered as surgical procedure' },
              { procedure: 'Porcelain Veneers', coverage: 'Usually $0', note: 'Classified cosmetic; exceptions for restorative cases' },
              { procedure: 'Dentures', coverage: '50%', note: 'Up to annual maximum, after waiting period' },
            ].map((row) => (
              <div class="flex items-center justify-between py-3 border-b border-neutral-border">
                <div class="text-sm font-medium text-brand-navy">{row.procedure}</div>
                <div class="text-right">
                  <div class="text-sm font-semibold text-brand-blue">{row.coverage}</div>
                  <div class="text-xs text-neutral-mid">{row.note}</div>
                </div>
              </div>
            ))}
          </div>
          <p class="text-xs text-neutral-mid mt-4 italic">Coverage percentages are general estimates. Your actual benefits depend on your specific plan. We verify your coverage before treatment begins.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Financing Options -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Financing Options</div>
        <h2 class="section-heading mb-4">Flexible payment plans available</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          We offer multiple financing options so you can start treatment now and pay over time — often with low or no interest.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- CareCredit -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-border shadow-sm">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">CareCredit</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-5">
            Healthcare credit card with promotional 0% interest periods of 6–24 months. Apply online in minutes — approval decisions are typically instant.
          </p>
          <ul class="space-y-2 mb-6">
            {['0% interest promotions available', '6, 12, 18, or 24-month terms', 'Instant online approval', 'Use for any treatment cost'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-neutral-mid">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="https://www.carecredit.com/apply/" target="_blank" rel="noopener noreferrer" class="block text-center btn-primary text-sm py-2.5">Apply for CareCredit</a>
        </div>

        <!-- Proceed Finance -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-border shadow-sm">
          <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">Proceed Finance</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-5">
            Longer-term fixed-rate financing for larger treatment amounts. Ideal for All-on-4, full-mouth reconstruction, or cases where you want extended repayment terms.
          </p>
          <ul class="space-y-2 mb-6">
            {['Terms up to 60 months', 'Fixed monthly payments', 'Designed for larger cases', 'Simple application process'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-neutral-mid">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="https://www.proceedfinance.com/" target="_blank" rel="noopener noreferrer" class="block text-center btn-secondary text-sm py-2.5">Learn About Proceed</a>
        </div>

        <!-- In-Office -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-border shadow-sm">
          <div class="w-12 h-12 bg-brand-light rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">Flexible Arrangements</h3>
          <p class="text-neutral-mid text-sm leading-relaxed mb-5">
            For multi-phase treatments like dental implants, we discuss timing and payment arrangements at your consultation. Many treatments are naturally spread across several appointments.
          </p>
          <ul class="space-y-2 mb-6">
            {['Payment timing tied to treatment phases', 'Clear cost breakdown upfront', 'No hidden fees', 'Discuss options at consultation'].map((item) => (
              <li class="flex items-start gap-2 text-sm text-neutral-mid">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/schedule" class="block text-center btn-secondary text-sm py-2.5">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost Guides -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Cost Guides</div>
        <h2 class="section-heading mb-4">What does treatment cost?</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          Our patient education guides explain what different treatments cost in Huntington Beach, why pricing varies, and how to evaluate quotes honestly.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            title: 'Dental Implants',
            range: '$3,000–$6,000',
            desc: 'Per tooth, including crown. Varies with bone grafting needs.',
            href: '/blog/dental-implant-cost-huntington-beach',
          },
          {
            title: 'All-on-4',
            range: '$20,000–$35,000',
            desc: 'Per arch, complete case with final zirconia prosthesis.',
            href: '/blog/all-on-4-cost-huntington-beach',
          },
          {
            title: 'Porcelain Veneers',
            range: '$1,200–$2,500',
            desc: 'Per tooth. Full smile (8–10 veneers) typically $12,000–$25,000.',
            href: '/blog/porcelain-veneers-cost-huntington-beach',
          },
          {
            title: 'Dentures',
            range: '$1,500–$35,000',
            desc: 'Wide range from conventional removable to fixed implant prosthetics.',
            href: '/blog/dentures-cost-huntington-beach',
          },
        ].map((item) => (
          <a href={item.href} class="card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group">
            <div class="text-xs text-brand-blue font-semibold uppercase tracking-wide mb-2">Cost Guide</div>
            <h3 class="font-serif text-lg font-semibold text-brand-navy mb-1 group-hover:text-brand-blue transition-colors">{item.title}</h3>
            <div class="text-brand-gold font-bold text-xl mb-3">{item.range}</div>
            <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
            <div class="mt-4 text-brand-blue text-sm font-medium flex items-center gap-1">
              Read full guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Reassurance Strip -->
  <section class="bg-brand-light py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        {[
          {
            icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
            title: 'Free Consultation',
            desc: 'Your first visit is complimentary. Get a full cost estimate before committing to anything.',
          },
          {
            icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
            title: 'No Hidden Fees',
            desc: 'We provide itemized treatment plans with exact costs — no surprises on your bill.',
          },
          {
            icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
            title: 'Financing Available',
            desc: 'Monthly payment options from $0 down. Apply online in minutes with instant approval.',
          },
        ].map((item) => (
          <div>
            <div class="w-10 h-10 bg-brand-blue/10 rounded-xl flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-brand-navy mb-1">{item.title}</h3>
            <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 bg-surface-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Common Questions About Insurance & Financing" />
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-16 pt-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Find out exactly what your care will cost"
        subheading="Your free consultation includes a full treatment plan and itemized cost breakdown. We verify your insurance benefits before you arrive."
      />
    </div>
  </section>

</BaseLayout>
