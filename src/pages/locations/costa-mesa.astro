---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import { localBusinessSchema as localBusiness } from '../../config/site';

const city = 'Costa Mesa';
const distance = '8 miles';
const driveTime = '14 minutes';

const faqs = [
  {
    question: 'Do you serve patients from Costa Mesa?',
    answer: 'Yes. Patients from Costa Mesa regularly travel to our Huntington Beach office for specialist implant and cosmetic care. We\'re located at 16141 Bolsa Chica St., Suite C — about 8 miles and 14 minutes from Costa Mesa. Most patients find the drive straightforward and worth it for specialist-level prosthodontic care.',
  },
  {
    question: 'What procedures do Costa Mesa patients most commonly come to you for?',
    answer: 'Dental implants and All-on-4 full-arch restorations are our most requested procedures from patients across Orange County. We also see patients from Costa Mesa for porcelain veneers, smile makeovers, implant-supported dentures, and complex restorative cases that require a prosthodontist.',
  },
  {
    question: 'Why would I travel to Huntington Beach instead of seeing a dentist in Costa Mesa?',
    answer: 'Prosthodontics is a dental specialty requiring three additional years of residency training beyond dental school. Dr. Favian Cheong completed his specialty training at UCSF. For complex procedures — implants, full-arch reconstruction, veneers, or cases involving multiple teeth — a prosthodontist brings a level of planning, materials knowledge, and technical precision that a general dentist typically cannot match. Most of our out-of-area patients tell us the difference in outcome quality made the drive entirely worthwhile.',
  },
  {
    question: 'How do I schedule a consultation from Costa Mesa?',
    answer: 'Call us at (714) 846-1386 or use our online appointment request form. We\'ll confirm your appointment by email or phone. The initial consultation includes a comprehensive exam and 3D imaging where appropriate.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(f => ({
    '@type': 'Question',
    'name': f.question,
    'acceptedAnswer': { '@type': 'Answer', 'text': f.answer },
  })),
};
---

<BaseLayout
  title="Prosthodontist Near Costa Mesa, CA | Dental Implants & Veneers | Dr. Favian Cheong"
  description="Serving patients from Costa Mesa, CA. Certified prosthodontist Dr. Favian Cheong offers dental implants, All-on-4, veneers & smile restoration. 8 miles from Costa Mesa."
  schema={[localBusiness, faqSchema]}
>

  <!-- Hero -->
  <section class="bg-brand-navy py-16 md:py-24 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-4">Serving Costa Mesa, CA</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Prosthodontist Near Costa Mesa, CA — Specialist Implant &amp; Cosmetic Dentistry
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          Costa Mesa blends urban energy with coastal proximity — and its residents bring the same mix of standards to their dental care. Huntington Beach Prosthodontics is just {distance} from Costa Mesa, about {driveTime} without freeway travel. Dr. Favian Cheong, a specialist-trained prosthodontist trained at UCLA and UCSF, offers Costa Mesa patients the specialist-level implant, restorative, and cosmetic dentistry that most people have to travel much further to find.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/schedule" class="btn-accent text-base px-8 py-4 font-semibold text-center">Book Free Consultation</a>
          <a href="tel:7148461386" class="text-white/90 font-medium text-base py-4 hover:text-white transition-colors text-center">(714) 846-1386</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why a Prosthodontist -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Specialist Training</div>
          <h2 class="section-heading mb-6">Why Costa Mesa patients choose a prosthodontist</h2>
          <p class="text-neutral-mid leading-relaxed mb-5">
            Costa Mesa residents have easy access to general dental offices — but a prosthodontist brings something qualitatively different. A prosthodontist is an ADA-recognized dental specialist with three years of dedicated residency training beyond dental school, focused entirely on restoring and replacing teeth. That specialization is the reason general dentists refer their most complex implant and cosmetic cases outward — and the reason patients who've experienced both describe the difference in unmistakable terms.
          </p>
          <p class="text-neutral-mid leading-relaxed mb-5">
            Dr. Favian Cheong completed his prosthodontic residency at UCSF and the VA San Francisco Medical Center. His training covered the full range of implant systems, full-arch prosthetic design, bite rehabilitation, and precision cosmetic restoration — cases that constitute the majority of what Huntington Beach Prosthodontics treats every day.
          </p>
          <p class="text-neutral-mid leading-relaxed mb-8">
            For Costa Mesa patients whose dental needs go beyond routine cleanings and basic restorations, the {driveTime} to Huntington Beach is a small investment for a substantially better outcome.
          </p>
          <a href="/why-a-prosthodontist" class="btn-primary text-base px-6 py-3">Why a Prosthodontist?</a>
        </div>
        <div class="space-y-4">
          {[
            { title: 'Residency-Level Expertise', desc: 'Three additional years of post-doctoral residency training focused exclusively on implants, full-arch prosthetics, bite rehabilitation, and cosmetic restoration.' },
            { title: 'ADA-Recognized Specialist', desc: 'One of only nine dental specialties formally recognized by the American Dental Association — the same designation as orthodontists and oral surgeons.' },
            { title: 'Trained Where Complex Cases Go', desc: 'UCSF and the VA San Francisco are referral destinations for the most complex prosthetic cases in Northern California. That\'s where Dr. Cheong trained.' },
            { title: 'General Dentists\' Referral Destination', desc: 'When your general dentist can\'t handle the complexity of your case, they send you to a prosthodontist. Dr. Cheong receives referrals from dozens of offices across Orange County.' },
          ].map(item => (
            <div class="card p-6">
              <h3 class="font-semibold text-brand-navy mb-2">{item.title}</h3>
              <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Treatments Available</div>
        <h2 class="section-heading mb-4">Services for Costa Mesa patients</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          Specialist-level care across the full range of implant, cosmetic, and restorative dentistry — available to Costa Mesa patients just {driveTime} away.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Dental Implants', desc: 'The most natural and permanent solution for missing teeth — designed and restored by a certified prosthodontic specialist for long-term function and aesthetics.', href: '/dental-implants' },
          { title: 'All-on-4 / All-on-6', desc: 'Full-arch restoration on four or six implants — the most comprehensive implant treatment available, replacing an entire row of missing or failing teeth.', href: '/all-on-x/all-on-4' },
          { title: 'Single Tooth Implants', desc: 'Replace an individual missing tooth with a titanium implant and custom crown — no involvement of adjacent teeth, permanent result.', href: '/dental-implants/single-tooth' },
          { title: 'Porcelain Veneers', desc: 'Thin, custom porcelain restorations that correct chips, gaps, discoloration, and proportion — with the shade precision and material knowledge of a prosthodontist.', href: '/veneers/porcelain' },
          { title: 'Smile Makeovers', desc: 'A comprehensive smile transformation — veneers, whitening, bonding, crowns, and implants combined in a single, coordinated aesthetic plan.', href: '/veneers/smile-makeover' },
          { title: 'Implant-Supported Dentures', desc: 'Dentures stabilized by implants for superior retention, comfort, and function. A major quality-of-life upgrade over conventional dentures.', href: '/implant-restorations/snap-on' },
          { title: 'Full Mouth Reconstruction', desc: 'For patients with widespread tooth loss, damage, or failing dentition — a complete prosthetic rehabilitation combining every tool in the prosthodontic toolkit.', href: '/all-on-x/full-mouth-reconstruction' },
          { title: 'Bone Grafting', desc: 'Restoring jaw bone volume lost to tooth extraction or long-term edentulism — an essential prerequisite for implant placement in many cases.', href: '/dental-implants/bone-grafting' },
        ].map(service => (
          <a href={service.href} class="card p-6 hover:shadow-md transition-shadow group">
            <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">{service.title}</h3>
            <p class="text-neutral-mid text-sm leading-relaxed">{service.desc}</p>
            <div class="mt-4 text-brand-blue text-sm font-medium">Learn more &rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Our Reputation</div>
        <h2 class="section-heading mb-4">4.9 stars — 73 Google reviews</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          Costa Mesa patients who've made the drive describe it as one of the best decisions they made for their dental health — and a standard of care they didn't know was available this close to home.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card p-8 text-center">
          <div class="text-4xl font-bold text-brand-gold mb-2">4.9</div>
          <div class="flex justify-center mb-3">
            {Array(5).fill(null).map(() => (
              <svg class="w-5 h-5 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <div class="text-neutral-mid text-sm">73 Verified Google Reviews</div>
        </div>
        <div class="card p-8 text-center">
          <div class="font-serif text-xl font-bold text-brand-navy mb-2">Dr. Favian Cheong</div>
          <div class="text-brand-blue text-sm font-medium mb-3">DDS, MS — Certified Prosthodontic Specialist</div>
          <p class="text-neutral-mid text-sm leading-relaxed">UCLA DDS. UCSF Prosthodontic Residency. ADA-recognized prosthodontic specialist. Serving Costa Mesa and Orange County patients with specialist-level care.</p>
        </div>
        <div class="card p-8 text-center">
          <div class="font-serif text-xl font-bold text-brand-navy mb-2">Dr. Janelle Cheong</div>
          <div class="text-brand-blue text-sm font-medium mb-3">General Dentist</div>
          <p class="text-neutral-mid text-sm leading-relaxed">General dentistry alongside Dr. Favian Cheong's specialist prosthodontic services — a complete dental practice in one location.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Getting Here -->
  <section class="bg-brand-light py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Getting Here</div>
          <h2 class="section-heading mb-6">From Costa Mesa to Huntington Beach — {driveTime}</h2>
          <p class="text-neutral-mid leading-relaxed mb-4">
            From Costa Mesa, take either Pacific Coast Highway or Newland Street northwest into Huntington Beach. The drive is approximately {distance} and takes around {driveTime} under normal traffic conditions. Our office is at 16141 Bolsa Chica St., Suite C — a professional medical building with convenient parking and straightforward access from Bolsa Chica Street.
          </p>
          <p class="text-neutral-mid leading-relaxed mb-8">
            Office hours: Monday, Wednesday, and Friday 9am–5pm; Saturday 10am–2pm. Tuesday and Thursday appointments available by arrangement.
          </p>
          <a
            href="https://maps.google.com/?q=16141+Bolsa+Chica+St+Suite+C+Huntington+Beach+CA+92649"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-base px-6 py-3"
          >
            Get Directions on Google Maps
          </a>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-border">
          <h3 class="font-serif text-lg font-semibold text-brand-navy mb-4">Office Address</h3>
          <address class="not-italic text-neutral-mid leading-relaxed mb-6">
            16141 Bolsa Chica St., Suite C<br />
            Huntington Beach, CA 92649
          </address>
          <h3 class="font-serif text-lg font-semibold text-brand-navy mb-4">Phone</h3>
          <a href="tel:7148461386" class="text-brand-blue font-medium text-lg hover:underline">(714) 846-1386</a>
          <div class="mt-6 pt-6 border-t border-neutral-border">
            <h3 class="font-serif text-lg font-semibold text-brand-navy mb-3">Hours</h3>
            <ul class="text-neutral-mid text-sm space-y-1">
              <li>Mon, Wed, Fri: 9am – 5pm</li>
              <li>Tue, Thu: By Appointment</li>
              <li>Sat: 10am – 2pm</li>
              <li>Sun: Closed</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading={`Common Questions from ${city} Patients`} />
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-16 pt-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Costa Mesa patients: your specialist is 14 minutes away"
        subheading="Book a complimentary consultation with Dr. Favian Cheong. No rush, no pressure — just expert prosthodontic assessment and a clear picture of your options."
      />
    </div>
  </section>

</BaseLayout>
