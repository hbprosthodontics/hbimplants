---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import { localBusinessSchema as localBusiness } from '../../config/site';

const city = 'Fountain Valley';
const distance = '6 miles';
const driveTime = '11 minutes';

const faqs = [
  {
    question: 'Do you serve patients from Fountain Valley?',
    answer: 'Yes. Patients from Fountain Valley regularly travel to our Huntington Beach office for specialist implant and cosmetic care. We\'re located at 16141 Bolsa Chica St., Suite C — about 6 miles and 11 minutes from Fountain Valley. Most patients find the drive straightforward and worth it for specialist-level prosthodontic care.',
  },
  {
    question: 'What procedures do Fountain Valley patients most commonly come to you for?',
    answer: 'Dental implants and All-on-4 full-arch restorations are our most requested procedures from patients across Orange County. We also see patients from Fountain Valley for porcelain veneers, smile makeovers, implant-supported dentures, and complex restorative cases that require a prosthodontist.',
  },
  {
    question: 'Why would I travel to Huntington Beach instead of seeing a dentist in Fountain Valley?',
    answer: 'Prosthodontics is a dental specialty requiring three additional years of residency training beyond dental school. Dr. Favian Cheong completed his specialty training at UCSF. For complex procedures — implants, full-arch reconstruction, veneers, or cases involving multiple teeth — a prosthodontist brings a level of planning, materials knowledge, and technical precision that a general dentist typically cannot match. Most of our out-of-area patients tell us the difference in outcome quality made the drive entirely worthwhile.',
  },
  {
    question: 'How do I schedule a consultation from Fountain Valley?',
    answer: 'Call us at (714) 846-1386 or use our online appointment request form. We\'ll confirm your appointment by email or phone. The initial consultation includes a comprehensive exam and 3D imaging where appropriate.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(f => ({
    '@type': 'Question',
    'name': f.question,
    'acceptedAnswer': { '@type': 'Answer', 'text': f.answer },
  })),
};
---

<BaseLayout
  title="Prosthodontist Near Fountain Valley, CA | Dental Implants & Veneers | Dr. Favian Cheong"
  description="Serving patients from Fountain Valley, CA. Certified prosthodontist Dr. Favian Cheong offers dental implants, All-on-4, veneers & smile restoration. 6 miles from Fountain Valley."
  schema={[localBusiness, faqSchema]}
>

  <!-- Hero -->
  <section class="bg-surface-2 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-teal text-sm font-semibold uppercase tracking-wide mb-4">Serving Fountain Valley, CA</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight text-charcoal">
          Prosthodontist Near Fountain Valley, CA — Specialist Implant &amp; Cosmetic Dentistry
        </h1>
        <p class="text-charcoal text-lg leading-relaxed mb-8">
          Fountain Valley sits right on the doorstep of Huntington Beach — our office is just {distance} away, roughly {driveTime} without freeway traffic. Residents looking for specialist-level dental care no longer need to travel far. Dr. Favian Cheong is a specialist-trained prosthodontist with UCLA and UCSF training who provides the kind of precise, specialist implant and cosmetic dentistry that most Orange County residents would have to drive to Los Angeles to access.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/schedule" class="btn-primary text-base px-8 py-4 font-semibold text-center">Book Consultation</a>
          <a href="tel:7148461386" class="text-charcoal font-medium text-base py-4 hover:text-charcoal transition-colors text-center">(714) 846-1386</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why a Prosthodontist -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Specialist Training</div>
          <h2 class="section-heading mb-6">Why Fountain Valley patients choose a prosthodontist</h2>
          <p class="text-charcoal leading-relaxed mb-5">
            Fountain Valley is a well-established community with access to good healthcare — but specialist prosthodontic care is rare anywhere. There are far fewer prosthodontists practicing in the United States than general dentists, and the right one for complex implant and cosmetic cases makes a significant difference in outcomes.
          </p>
          <p class="text-charcoal leading-relaxed mb-5">
            A prosthodontist completes dental school, then an additional three-year ADA-accredited specialty residency focused exclusively on tooth restoration and replacement. That means implants in compromised bone, full-arch prosthetics, precision cosmetic veneers, bite rehabilitation, and complete smile reconstruction — cases that take far more training than any continuing education course can provide.
          </p>
          <p class="text-charcoal leading-relaxed mb-8">
            Dr. Cheong trained at UCSF, the same institution that attracts some of the most difficult prosthetic cases in the country through its dental school clinics. Fountain Valley patients benefit from that depth of experience every time they sit in the chair.
          </p>
          <a href="/why-a-prosthodontist" class="btn-primary text-base px-6 py-3">The Prosthodontics Difference</a>
        </div>
        <div class="space-y-4">
          {[
            { title: 'Dental School + 3-Year Specialty Residency', desc: 'A prosthodontist invests seven-plus years in training before practicing — three of those years exclusively in specialty implant and restorative techniques.' },
            { title: 'Focused on Restoration & Replacement', desc: 'Unlike general dentists who cover the full spectrum of dental care, a prosthodontist\'s entire focus is restoring damaged and replacing missing teeth.' },
            { title: 'ADA Specialty Recognition', desc: 'Prosthodontics is an officially recognized specialty by the American Dental Association — not a certificate program or advanced training course.' },
            { title: 'Who Gets Referrals From General Dentists', desc: 'When a general dentist encounters a case beyond their scope, they refer to a prosthodontist. That\'s the role Dr. Cheong fills for dozens of referring offices across Orange County.' },
          ].map(item => (
            <div class="card p-6">
              <h3 class="font-semibold text-brand-navy mb-2">{item.title}</h3>
              <p class="text-charcoal text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Treatments Available</div>
        <h2 class="section-heading mb-4">Services for Fountain Valley patients</h2>
        <p class="text-charcoal max-w-2xl mx-auto leading-relaxed">
          Specialist-level care in every category — from a single implant to a complete full-arch reconstruction.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Dental Implants', desc: 'The most functional, long-lasting solution for missing teeth — a titanium root topped with a custom crown that looks and acts like your natural tooth.', href: '/dental-implants' },
          { title: 'All-on-4 / All-on-6', desc: 'Teeth-in-a-day full-arch restoration. Replace an entire set of failing or missing teeth with a fixed prosthesis on as few as four implants.', href: '/all-on-x/all-on-4' },
          { title: 'Single Tooth Implants', desc: 'Isolated tooth replacement without affecting adjacent teeth. The conservative, long-term alternative to a dental bridge.', href: '/dental-implants/single-tooth' },
          { title: 'Porcelain Veneers', desc: 'Custom-crafted veneers that transform the color, shape, and proportion of your smile — with results that hold up for fifteen years and beyond.', href: '/veneers/porcelain' },
          { title: 'Smile Makeovers', desc: 'Combine veneers, whitening, bonding, crowns, and implants into one coordinated smile transformation plan.', href: '/veneers/smile-makeover' },
          { title: 'Implant-Supported Dentures', desc: 'Snap-on or fixed dentures anchored by implants — a dramatic improvement over conventional dentures in comfort, confidence, and chewing ability.', href: '/implant-restorations/snap-on' },
          { title: 'Full Mouth Reconstruction', desc: 'Comprehensive rehabilitation for a mouth with widespread damage, failing teeth, or complete edentulism — all planned as one coordinated treatment.', href: '/all-on-x/full-mouth-reconstruction' },
          { title: 'Bone Grafting', desc: 'Preparing the jaw for implants when bone loss has occurred — socket preservation, ridge augmentation, and sinus lifts as needed.', href: '/dental-implants/bone-grafting' },
        ].map(service => (
          <a href={service.href} class="card p-6 hover:shadow-md transition-shadow group">
            <h3 class="font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">{service.title}</h3>
            <p class="text-charcoal text-sm leading-relaxed">{service.desc}</p>
            <div class="mt-4 text-brand-blue text-sm font-medium">Learn more &rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Our Reputation</div>
        <h2 class="section-heading mb-4">4.9 stars — 73 reviews and counting</h2>
        <p class="text-charcoal max-w-2xl mx-auto leading-relaxed">
          The reviews speak for themselves. Patients describe results they didn't think were possible — and a practice experience that felt different from the start.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card p-8 text-center">
          <div class="text-4xl font-bold text-brand-teal mb-2">4.9</div>
          <div class="flex justify-center mb-3">
            {Array(5).fill(null).map(() => (
              <svg class="w-5 h-5 text-brand-teal" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <div class="text-charcoal text-sm">73 Google Reviews</div>
        </div>
        <div class="card p-8 text-center">
          <div class="font-serif text-xl font-bold text-brand-navy mb-2">Dr. Favian Cheong</div>
          <div class="text-brand-blue text-sm font-medium mb-3">DDS, MS — Certified Prosthodontic Specialist</div>
          <p class="text-charcoal text-sm leading-relaxed">UC Irvine. UCLA School of Dentistry. UCSF Prosthodontic Residency. ADA-Recognized Specialist.</p>
        </div>
        <div class="card p-8 text-center">
          <div class="font-serif text-xl font-bold text-brand-navy mb-2">Dr. Janelle Cheong</div>
          <div class="text-brand-blue text-sm font-medium mb-3">General Dentist</div>
          <p class="text-charcoal text-sm leading-relaxed">Comprehensive general dentistry care available alongside Dr. Favian Cheong's specialist prosthodontic services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Getting Here -->
  <section class="bg-brand-light py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Getting Here</div>
          <h2 class="section-heading mb-6">From Fountain Valley to Huntington Beach — {driveTime}</h2>
          <p class="text-charcoal leading-relaxed mb-4">
            From Fountain Valley, head south on Magnolia Street or Brookhurst Street toward Huntington Beach. The drive is approximately {distance} and takes around {driveTime} under typical conditions. Our office at 16141 Bolsa Chica St., Suite C is easily accessible with convenient on-site parking.
          </p>
          <p class="text-charcoal leading-relaxed mb-8">
            We are open Monday, Wednesday, Thursday, and Friday 9am–5pm. Tuesday is by appointment only. Saturday and Sunday are closed.
          </p>
          <a
            href="https://maps.google.com/?q=16141+Bolsa+Chica+St+Suite+C+Huntington+Beach+CA+92649"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-base px-6 py-3"
          >
            Get Directions on Google Maps
          </a>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-border">
          <h3 class="font-serif text-lg font-semibold text-brand-navy mb-4">Office Address</h3>
          <address class="not-italic text-charcoal leading-relaxed mb-6">
            16141 Bolsa Chica St., Suite C<br />
            Huntington Beach, CA 92649
          </address>
          <h3 class="font-serif text-lg font-semibold text-brand-navy mb-4">Phone</h3>
          <a href="tel:7148461386" class="text-brand-blue font-medium text-lg hover:underline">(714) 846-1386</a>
          <div class="mt-6 pt-6 border-t border-neutral-border">
            <h3 class="font-serif text-lg font-semibold text-brand-navy mb-3">Hours</h3>
            <ul class="text-charcoal text-sm space-y-1">
              <li>Mon: 9am – 5pm</li>
              <li>Tue: By Appointment</li>
              <li>Wed: 9am – 5pm</li>
              <li>Thu: 9am – 5pm</li>
              <li>Fri: 9am – 5pm</li>
              <li>Sat: Closed</li>
              <li>Sun: Closed</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading={`Common Questions from ${city} Patients`} />
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-16 pt-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock
        heading="Fountain Valley patients: specialist care is closer than you think"
        subheading="Book a consultation with Dr. Favian Cheong. Get a full clinical assessment, honest answers, and a clear treatment plan — just {driveTime} from Fountain Valley."
      />
    </div>
  </section>

</BaseLayout>
