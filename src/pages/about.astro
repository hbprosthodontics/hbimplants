---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import FAQBlock from '../components/FAQBlock.astro';

const faqs = [
  {
    question: 'Is Dr. Favian Cheong board-certified?',
    answer: 'Yes. Dr. Favian Cheong is a board-certified prosthodontist who completed a CODA-accredited three-year prosthodontic residency at UCSF and the VA San Francisco Medical Center. Prosthodontics is one of nine dental specialties officially recognized by the American Dental Association.',
  },
  {
    question: 'What is the difference between a prosthodontist and a general dentist?',
    answer: 'A prosthodontist completes three additional years of post-doctoral specialty training beyond dental school — focused exclusively on complex tooth restoration and replacement, implants, and cosmetic rehabilitations. General dentists provide excellent routine and preventive care, but when treatment involves missing teeth, implants, full-arch restorations, veneers, or complex smile design, a prosthodontist brings a higher level of precision and expertise.',
  },
  {
    question: 'Do both doctors see new patients?',
    answer: 'Yes. Dr. Favian Cheong sees patients for prosthodontic and implant procedures, while Dr. Janelle Cheong handles general dental care including cleanings, exams, fillings, and crowns. Many patients benefit from having both doctors coordinate their care under one roof.',
  },
  {
    question: 'How do I know which doctor is right for me?',
    answer: 'If you\'re interested in dental implants, full-arch restorations, veneers, or complex smile rehabilitation, Dr. Favian Cheong is the specialist you want. For general dental care, routine check-ups, or if you\'re unsure where to start, Dr. Janelle Cheong is an excellent first contact. Our team will help guide you to the right appointment when you call or submit our online form.',
  },
  {
    question: 'What should I expect at my first visit?',
    answer: 'Your first appointment includes a comprehensive oral examination, complete digital records (X-rays and photographs), and an in-depth conversation about your goals and concerns. You\'ll receive an honest assessment of your options with clear information on timelines and costs — with no pressure or obligation to proceed on the same day.',
  },
  {
    question: 'What advanced technology does the practice use?',
    answer: 'We use advanced 3D cone-beam CT (CBCT) imaging, intraoral digital scanning, intraoral photography, and digital impressions. These tools allow us to plan implant placement with high precision, detect issues invisible on standard X-rays, and give patients a clear visual understanding of their own anatomy and treatment plan.',
  },
];

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'email': 'hbprosth@gmail.com',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};

const physicians = [
  {
    '@context': 'https://schema.org',
    '@type': 'Physician',
    'name': 'Dr. Favian Cheong',
    'medicalSpecialty': 'Prosthodontics',
    'affiliation': { '@type': 'Organization', 'name': 'Huntington Beach Prosthodontics' },
    'alumniOf': [
      { '@type': 'EducationalOrganization', 'name': 'UC Irvine' },
      { '@type': 'EducationalOrganization', 'name': 'UCLA School of Dentistry' },
      { '@type': 'EducationalOrganization', 'name': 'UCSF / VA San Francisco Prosthodontic Residency' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Physician',
    'name': 'Dr. Janelle Cheong',
    'medicalSpecialty': 'General Dentistry',
    'affiliation': { '@type': 'Organization', 'name': 'Huntington Beach Prosthodontics' },
    'alumniOf': [
      { '@type': 'EducationalOrganization', 'name': 'UCLA School of Dentistry' },
      { '@type': 'EducationalOrganization', 'name': 'UCLA Advanced Education in General Dentistry' },
    ],
  },
];
---

<BaseLayout
  title="Dr. Favian Cheong | Prosthodontist Huntington Beach"
  description="Meet Dr. Favian Cheong, prosthodontist, and Dr. Janelle Cheong, DDS, at Huntington Beach Prosthodontics. Specialist-level implant and cosmetic dentistry."
  schema={[localBusiness, ...physicians]}
>
  <!-- Hero -->
  <section class="bg-brand-navy py-16 md:py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-3">About Our Practice</div>
          <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
            Specialist care.<br />
            <span class="text-brand-gold">Two UCLA-trained doctors.</span>
          </h1>
          <p class="text-white/80 text-lg leading-relaxed mb-8">
            Dr. Favian Cheong is a board-certified prosthodontist — one of nine ADA-recognized dental specialists — who completed his residency at UCSF. Dr. Janelle Cheong provides comprehensive general dental care. Together, they offer specialist-level and preventive care under one roof.
          </p>
          <div class="flex flex-wrap gap-6">
            {[
              { label: 'Board-Certified', sub: 'Prosthodontist' },
              { label: 'UCLA + UCSF', sub: 'Trained' },
              { label: 'ADA Recognized', sub: 'Specialty' },
            ].map((stat) => (
              <div>
                <div class="text-white font-bold text-lg">{stat.label}</div>
                <div class="text-white/60 text-sm">{stat.sub}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="hidden lg:block">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <img src="/images/dr-favian-cheong.png" alt="Dr. Favian Cheong" class="rounded-2xl w-full aspect-[3/4] object-cover object-top" />
              <div class="bg-white/10 rounded-xl p-4 border border-white/20">
                <div class="font-semibold text-white text-sm">Dr. Favian Cheong</div>
                <div class="text-brand-gold text-xs font-medium">Prosthodontist</div>
              </div>
            </div>
            <div class="space-y-4 mt-8">
              <div class="bg-white/10 rounded-xl p-4 border border-white/20">
                <div class="font-semibold text-white text-sm">Dr. Janelle Cheong</div>
                <div class="text-white/60 text-xs">General Dentist</div>
              </div>
              <img src="/images/dr-janelle-cheong.png" alt="Dr. Janelle Cheong" class="rounded-2xl w-full aspect-[3/4] object-cover object-top" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dr. Favian Cheong Bio -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <img
            src="/images/dr-favian-cheong.png"
            alt="Dr. Favian Cheong, Prosthodontist at Huntington Beach Prosthodontics"
            class="rounded-2xl w-full aspect-[4/5] object-cover object-top"
          />
        </div>

        <div>
          <div class="inline-block bg-brand-light text-brand-blue text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">Board-Certified Prosthodontist</div>
          <h2 class="section-heading mb-6">Dr. Favian Cheong</h2>

          <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
            Hi! I'm Dr. Favian Cheong — a Southern California native, born and raised in Long Beach, CA. I attended UC Irvine where I received my B.S. in Biological Sciences with a Minor in Psychology and Human Behavior. I then attended UCLA where I received my Doctor of Dental Surgery degree.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            After dental school, my goal was to treat patients with a range of needs — from cosmetic and restorative treatment to complex functional issues that go beyond the scope of general dentistry. So I continued my education at UC San Francisco and the Veterans Affairs San Francisco Medical Center, where I was certified as a specialist in prosthodontics — one of nine dental specialties accredited by the American Dental Association.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            A prosthodontist is a dentist who has completed three additional years of intensive post-doctoral training in a CODA-accredited graduate prosthodontic program — specifically focused on the restoration and replacement of teeth. This training covers everything from single implant crowns to full-arch rehabilitation, from precision veneers to complete mouth reconstructions.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-6">
            With my background in psychology, I understand the functional, psychological, and social importance of a healthy, confident smile. Whether your needs are minor or major, your treatment will be performed with precision and care at the highest level. I actively listen to your goals so I can guide you toward the best options — ones that will last a lifetime.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              { label: 'Undergraduate', value: 'UC Irvine — B.S. Biological Sciences' },
              { label: 'Dental School', value: 'UCLA — Doctor of Dental Surgery' },
              { label: 'Specialty Residency', value: 'UCSF / VA San Francisco' },
              { label: 'Specialty', value: 'Prosthodontics (ADA Recognized)' },
            ].map((item) => (
              <div class="bg-surface-2 rounded-lg p-4">
                <div class="text-xs text-neutral-mid font-medium uppercase tracking-wide mb-1">{item.label}</div>
                <div class="font-semibold text-brand-navy text-sm">{item.value}</div>
              </div>
            ))}
          </div>

          <a href="/schedule" class="btn-primary">Schedule with Dr. Favian Cheong</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Dr. Janelle Cheong Bio -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="order-2 lg:order-1">
          <div class="inline-block bg-white text-brand-blue text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">General Dentist</div>
          <h2 class="section-heading mb-6">Dr. Janelle Cheong</h2>

          <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
            Dr. Janelle Cheong is a Southern California native who spent 10 years at UCLA — earning both her Bachelor of Science in Physiological Science and her Doctor of Dental Surgery degree. After graduating from dental school in 2016, she completed a postgraduate residency in the UCLA Advanced Education in General Dentistry program.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            Since her residency, Dr. Janelle has worked in dental offices throughout the Bay Area and Southern California, bringing a wide range of clinical experience to her practice. She is affiliated with the American Dental Association, the California Dental Association, and the Harbor Dental Society. Dr. Janelle strives to create a comfortable experience while delivering quality care across all general dental services — cleanings, examinations, fillings, and crowns.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-6">
            Outside the office, Dr. Janelle enjoys spending time with her husband and two sons. She's also an avid baker and loves playing soccer and golf.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              { label: 'Undergraduate', value: 'UCLA — B.S. Physiological Science' },
              { label: 'Dental School', value: 'UCLA — Doctor of Dental Surgery (2016)' },
              { label: 'Residency', value: 'UCLA Advanced Education in General Dentistry' },
              { label: 'Affiliations', value: 'ADA · CDA · Harbor Dental Society' },
            ].map((item) => (
              <div class="bg-white rounded-lg p-4">
                <div class="text-xs text-neutral-mid font-medium uppercase tracking-wide mb-1">{item.label}</div>
                <div class="font-semibold text-brand-navy text-sm">{item.value}</div>
              </div>
            ))}
          </div>

          <a href="/schedule" class="btn-secondary">Schedule with Dr. Janelle Cheong</a>
        </div>

        <div class="order-1 lg:order-2">
          <img
            src="/images/dr-janelle-cheong.png"
            alt="Dr. Janelle Cheong, DDS at Huntington Beach Prosthodontics"
            class="rounded-2xl w-full aspect-[4/5] object-cover object-top"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Philosophy -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">Our Philosophy of Care</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          We believe every patient deserves a customized treatment plan built around their specific anatomy, goals, and life circumstances — not a one-size-fits-all solution.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: 'Specialist Expertise',
            desc: 'Dr. Favian Cheong is a board-certified prosthodontist with three additional years of post-doctoral training focused exclusively on restoring and replacing teeth at the highest level.',
          },
          {
            title: 'Technology-First Approach',
            desc: 'Advanced 3D CBCT imaging, digital oral scanning, intraoral photography, and digital impressions deliver precision and predictability that traditional methods cannot match.',
          },
          {
            title: 'Patient-Centered Care',
            desc: 'Your initial visit includes a thorough medical and dental history review, a complete examination, and an honest discussion of treatment options, timelines, and costs — before any commitment.',
          },
        ].map((item) => (
          <div class="bg-surface-2 rounded-xl p-6 text-center">
            <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">{item.title}</h3>
            <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why a Prosthodontist CTA Strip -->
  <section class="bg-brand-light py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <div class="font-semibold text-brand-navy text-lg mb-1">What makes a prosthodontist different?</div>
          <p class="text-neutral-mid text-sm">Three extra years of specialty training in implants, full-arch reconstruction, and smile rehabilitation. See how it compares.</p>
        </div>
        <a href="/why-a-prosthodontist" class="btn-primary whitespace-nowrap flex-shrink-0">Why a Prosthodontist</a>
      </div>
    </div>
  </section>

  <!-- Patient Reviews -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-blue text-sm font-semibold uppercase tracking-wide mb-3">Patient Reviews</div>
        <h2 class="section-heading mb-4">What patients say</h2>
        <div class="flex items-center justify-center gap-1 mb-2">
          {[1,2,3,4,5].map(() => (
            <svg class="w-6 h-6 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
        </div>
        <p class="text-neutral-mid text-sm">4.9 on Google · <a href="https://g.page/r/CU4itT3RNhmQEBM/review" target="_blank" rel="noopener noreferrer" class="text-brand-blue hover:underline">Leave a review</a></p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            quote: "Dr. Cheong is the most thorough dentist I've ever seen. He spent real time explaining my options and I never felt rushed or pressured. The implant has been perfect.",
            name: "Michael T.",
            detail: "Dental Implant Patient",
          },
          {
            quote: "I came in thinking I wasn't a candidate for implants because of bone loss. Dr. Cheong showed me exactly what the scan showed and laid out a real plan. I have my implants now and they're great.",
            name: "Sandra L.",
            detail: "All-on-4 Patient",
          },
          {
            quote: "I'd been embarrassed by my smile for years. Dr. Cheong did my veneers and the result is exactly what I wanted — natural looking, not overdone. Couldn't be happier.",
            name: "Jennifer R.",
            detail: "Porcelain Veneer Patient",
          },
        ].map((review) => (
          <div class="bg-surface-2 rounded-2xl p-7 border border-neutral-border">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-neutral-mid text-sm leading-relaxed mb-5 italic">"{review.quote}"</p>
            <div>
              <div class="font-semibold text-brand-navy text-sm">{review.name}</div>
              <div class="text-xs text-neutral-mid">{review.detail}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 bg-surface-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Questions About Our Doctors & Practice" />
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-16 pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock heading="Meet Dr. Favian Cheong In Person" subheading="Your first visit includes a thorough examination, complete records, and an honest discussion of your treatment options — no pressure, no surprises." />
    </div>
  </section>
</BaseLayout>
