---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'email': 'hbprosth@gmail.com',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};

const physicians = [
  {
    '@context': 'https://schema.org',
    '@type': 'Physician',
    'name': 'Dr. Favian Cheong',
    'medicalSpecialty': 'Prosthodontics',
    'affiliation': { '@type': 'Organization', 'name': 'Huntington Beach Prosthodontics' },
    'alumniOf': [
      { '@type': 'EducationalOrganization', 'name': 'UC Irvine' },
      { '@type': 'EducationalOrganization', 'name': 'UCLA School of Dentistry' },
      { '@type': 'EducationalOrganization', 'name': 'UCSF / VA San Francisco Prosthodontic Residency' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Physician',
    'name': 'Dr. Janelle Cheong',
    'medicalSpecialty': 'General Dentistry',
    'affiliation': { '@type': 'Organization', 'name': 'Huntington Beach Prosthodontics' },
    'alumniOf': [
      { '@type': 'EducationalOrganization', 'name': 'UCLA School of Dentistry' },
      { '@type': 'EducationalOrganization', 'name': 'UCLA Advanced Education in General Dentistry' },
    ],
  },
];
---

<BaseLayout
  title="About Dr. Favian Cheong | Prosthodontist in Huntington Beach, CA"
  description="Meet Dr. Favian Cheong, prosthodontist, and Dr. Janelle Cheong, DDS, at Huntington Beach Prosthodontics. Specialist-level implant and cosmetic dentistry."
  schema={[localBusiness, ...physicians]}
>
  <!-- Hero -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-3">About Our Practice</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Meet the Doctors at<br />
          <span class="text-brand-gold">Huntington Beach Prosthodontics</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed">
          Our team combines specialist-level prosthodontic expertise with comprehensive general dental care — giving every patient access to the highest standard of treatment under one roof.
        </p>
      </div>
    </div>
  </section>

  <!-- Dr. Favian Cheong Bio -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <img
            src="/images/dr-favian-cheong.png"
            alt="Dr. Favian Cheong, Prosthodontist at Huntington Beach Prosthodontics"
            class="rounded-2xl w-full aspect-[4/5] object-cover object-top"
          />
        </div>

        <div>
          <div class="inline-block bg-brand-light text-brand-blue text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">Board-Certified Prosthodontist</div>
          <h2 class="section-heading mb-6">Dr. Favian Cheong</h2>

          <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
            Hi! I'm Dr. Favian Cheong — a Southern California native, born and raised in Long Beach, CA. I attended UC Irvine where I received my B.S. in Biological Sciences with a Minor in Psychology and Human Behavior. I then attended UCLA where I received my Doctor of Dental Surgery degree.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            After dental school, my goal was to treat patients with a range of needs — from cosmetic and restorative treatment to complex functional issues that go beyond the scope of general dentistry. So I continued my education at UC San Francisco and the Veterans Affairs San Francisco Medical Center, where I was certified as a specialist in prosthodontics — one of nine dental specialties accredited by the American Dental Association.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            A prosthodontist is a dentist who has completed three additional years of intensive post-doctoral training in a CODA-accredited graduate prosthodontic program — specifically focused on the restoration and replacement of teeth. This training covers everything from single implant crowns to full-arch rehabilitation, from precision veneers to complete mouth reconstructions.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-6">
            With my background in psychology, I understand the functional, psychological, and social importance of a healthy, confident smile. Whether your needs are minor or major, your treatment will be performed with precision and care at the highest level. I actively listen to your goals so I can guide you toward the best options — ones that will last a lifetime.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              { label: 'Undergraduate', value: 'UC Irvine — B.S. Biological Sciences' },
              { label: 'Dental School', value: 'UCLA — Doctor of Dental Surgery' },
              { label: 'Specialty Residency', value: 'UCSF / VA San Francisco' },
              { label: 'Specialty', value: 'Prosthodontics (ADA Recognized)' },
            ].map((item) => (
              <div class="bg-surface-2 rounded-lg p-4">
                <div class="text-xs text-neutral-mid font-medium uppercase tracking-wide mb-1">{item.label}</div>
                <div class="font-semibold text-brand-navy text-sm">{item.value}</div>
              </div>
            ))}
          </div>

          <a href="/schedule" class="btn-primary">Schedule with Dr. Favian Cheong</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Dr. Janelle Cheong Bio -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="order-2 lg:order-1">
          <div class="inline-block bg-white text-brand-blue text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">General Dentist</div>
          <h2 class="section-heading mb-6">Dr. Janelle Cheong</h2>

          <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
            Dr. Janelle Cheong is a Southern California native who spent 10 years at UCLA — earning both her Bachelor of Science in Physiological Science and her Doctor of Dental Surgery degree. After graduating from dental school in 2016, she completed a postgraduate residency in the UCLA Advanced Education in General Dentistry program.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-4">
            Since her residency, Dr. Janelle has worked in dental offices throughout the Bay Area and Southern California, bringing a wide range of clinical experience to her practice. She is affiliated with the American Dental Association, the California Dental Association, and the Harbor Dental Society. Dr. Janelle strives to create a comfortable experience while delivering quality care across all general dental services — cleanings, examinations, fillings, and crowns.
          </p>

          <p class="text-neutral-mid leading-relaxed mb-6">
            Outside the office, Dr. Janelle enjoys spending time with her husband and two sons. She's also an avid baker and loves playing soccer and golf.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              { label: 'Undergraduate', value: 'UCLA — B.S. Physiological Science' },
              { label: 'Dental School', value: 'UCLA — Doctor of Dental Surgery (2016)' },
              { label: 'Residency', value: 'UCLA Advanced Education in General Dentistry' },
              { label: 'Affiliations', value: 'ADA · CDA · Harbor Dental Society' },
            ].map((item) => (
              <div class="bg-white rounded-lg p-4">
                <div class="text-xs text-neutral-mid font-medium uppercase tracking-wide mb-1">{item.label}</div>
                <div class="font-semibold text-brand-navy text-sm">{item.value}</div>
              </div>
            ))}
          </div>

          <a href="/schedule" class="btn-secondary">Schedule with Dr. Janelle Cheong</a>
        </div>

        <div class="order-1 lg:order-2">
          <img
            src="/images/dr-janelle-cheong.png"
            alt="Dr. Janelle Cheong, DDS at Huntington Beach Prosthodontics"
            class="rounded-2xl w-full aspect-[4/5] object-cover object-top"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Practice Philosophy -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">Our Philosophy of Care</h2>
        <p class="text-neutral-mid max-w-2xl mx-auto leading-relaxed">
          We believe every patient deserves a customized treatment plan built around their specific anatomy, goals, and life circumstances — not a one-size-fits-all solution.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: 'Specialist Expertise',
            desc: 'Dr. Favian Cheong is a board-certified prosthodontist with three additional years of post-doctoral training focused exclusively on restoring and replacing teeth at the highest level.',
          },
          {
            title: 'Technology-First Approach',
            desc: 'Advanced 3D CBCT imaging, digital oral scanning, intraoral photography, and digital impressions deliver precision and predictability that traditional methods cannot match.',
          },
          {
            title: 'Patient-Centered Care',
            desc: 'Your initial visit includes a thorough medical and dental history review, a complete examination, and an honest discussion of treatment options, timelines, and costs — before any commitment.',
          },
        ].map((item) => (
          <div class="bg-surface-2 rounded-xl p-6 text-center">
            <h3 class="font-serif text-xl font-semibold text-brand-navy mb-3">{item.title}</h3>
            <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock heading="Meet Dr. Favian Cheong In Person" subheading="Your first visit includes a thorough examination, complete records, and an honest discussion of your treatment options — no pressure, no surprises." />
    </div>
  </section>
</BaseLayout>
