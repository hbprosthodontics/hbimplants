---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

import { localBusinessSchema as localBusiness } from '../../config/site';
const procedureSchema = { '@context': 'https://schema.org', '@type': 'MedicalProcedure', 'name': 'Implant-Supported Dentures', 'description': 'A full-arch prosthesis permanently anchored to 4–6 dental implants, replacing all teeth in an arch with a fixed, non-removable restoration.', 'procedureType': 'https://schema.org/TherapeuticProcedure', 'bodyLocation': 'Mouth' };
const faqs = [
  { question: 'What is an implant-supported denture?', answer: 'An implant-supported denture is a full-arch prosthesis — replacing all teeth in the upper or lower jaw — that is permanently anchored to 4–6 dental implants. Unlike conventional dentures that rest on gum tissue, implant-supported dentures are fixed and non-removable. They do not slip, require no adhesives, and cannot fall out. They function and feel far more like natural teeth than any removable denture alternative.' },
  { question: 'How many implants are needed for an implant-supported denture?', answer: 'For a fixed, non-removable implant-supported denture, 4–6 implants per arch are typically required. The exact number depends on bone density, arch size, bite forces, and the prosthesis design. All-on-4 uses 4 implants per arch with strategically angled posterior implants. All-on-6 uses 6 implants for additional support and distribution of force, which is particularly beneficial for the upper arch and patients with heavy bite forces.' },
  { question: 'Is an implant-supported denture the same as All-on-4?', answer: 'All-on-4 is a specific implant-supported denture protocol using 4 implants per arch, with the two posterior implants angled at 30–45 degrees to maximize bone contact and often avoid bone grafting. An implant-supported denture is the broader category — it includes All-on-4, All-on-6, and other full-arch implant configurations. The prosthesis itself (the teeth) can be acrylic, hybrid zirconia, or monolithic zirconia depending on your budget and preferences.' },
  { question: 'How does an implant-supported denture compare to a conventional denture?', answer: 'Conventional dentures rest on gum tissue and rely on suction, natural retention, or adhesives — they move during eating and speaking and worsen over time as bone resorbs. Implant-supported dentures are anchored to the jawbone. They do not move. They do not require adhesives. They do not accelerate bone loss — in fact, they actively preserve bone by transmitting chewing forces into the jaw. Quality of life improvements reported by patients who switch from conventional dentures to implant-supported dentures are consistently dramatic.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Implant-Supported Dentures Huntington Beach, CA"
  description="Implant-supported dentures in Huntington Beach replace all teeth in an arch permanently. Fixed, non-removable, no adhesives. Prosthodontist-designed results."
  schema={[localBusiness, procedureSchema, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Implant-Supported Dentures Huntington Beach —<br />
          <span class="text-brand-teal">A Full Arch, Fixed Permanently to Implants</span>
        </h1>
        <p class="text-charcoal text-lg leading-relaxed mb-8">Replace all missing teeth in an arch with a fixed, non-removable prosthesis anchored to 4–6 implants. No slipping. No adhesives. No bone loss. A complete smile that functions like natural teeth.</p>
        <a href="/schedule" class="btn-accent text-base px-8 py-4 font-semibold">Schedule Your Implant Denture Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="section-heading mb-6">Fixed Full-Arch Replacement: The Implant-Supported Denture</h2>
      <p class="text-charcoal leading-relaxed mb-4 text-lg">
        An implant-supported denture is the gold standard for patients who need to replace an entire arch of teeth. Four to six titanium implants are surgically placed into the jawbone and allowed to integrate (fuse) with the bone. Once integrated, a custom-fabricated prosthesis — the actual teeth — is permanently attached to these implants, creating a full arch of fixed, non-removable teeth.
      </p>
      <p class="text-charcoal leading-relaxed mb-4">
        The experience of wearing implant-supported dentures compared to conventional dentures is so profoundly different that patients consistently describe it as life-changing. Conventional dentures rest on gum tissue. They move. They affect speech. They limit what you can eat. They require adhesives. They cause the jawbone to gradually resorb and shrink, altering your facial structure over years. An implant-supported denture eliminates every one of these problems.
      </p>
      <p class="text-charcoal leading-relaxed mb-4">
        The prosthesis — the part that looks like teeth — can be fabricated from several materials. Acrylic (the same material used in conventional dentures) is the most economical and is often used for the temporary prosthesis worn during healing. Hybrid zirconia is a more durable option: a zirconia substructure with layered porcelain for aesthetics. Monolithic zirconia (a solid block of zirconia) is the most durable, most stain-resistant, and most natural-appearing option available — many prosthodontists now consider it the optimal long-term choice for implant-supported full arch prostheses.
      </p>
      <p class="text-charcoal leading-relaxed mb-6">
        At Huntington Beach Prosthodontics, Dr. Favian Cheong designs every implant-supported denture with precise attention to occlusion (bite), phonetics (speech), and aesthetics (appearance). These three parameters are interdependent and must be planned together — an error in any one affects the others. The prosthodontist's unique training in prosthetic design is the primary reason implant-supported dentures from a specialist practice consistently outperform those from general dental offices. For more on full-arch options, see our <a href="/all-on-x" class="text-brand-blue hover:underline">All-on-4 and All-on-X page</a> or <a href="/implant-restorations/snap-on" class="text-brand-blue hover:underline">snap-on denture option</a>.
      </p>

      <h2 class="section-subheading mt-10 mb-6">Implant Denture Materials Compared</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-2">
              <th class="px-4 py-3 text-left font-semibold">Material</th>
              <th class="px-4 py-3 text-center font-semibold">Durability</th>
              <th class="px-4 py-3 text-center font-semibold">Aesthetics</th>
              <th class="px-4 py-3 text-center font-semibold">Stain Resistance</th>
              <th class="px-4 py-3 text-center font-semibold">Typical Use</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-border">
            {[
              ['Acrylic', 'Moderate', 'Good', 'Fair', 'Temporary / budget'],
              ['Hybrid Zirconia', 'High', 'Excellent', 'Very Good', 'Long-term standard'],
              ['Monolithic Zirconia', 'Exceptional', 'Excellent', 'Exceptional', 'Premium permanent'],
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-brand-light'}>
                {row.map((cell, j) => (
                  <td class={`px-4 py-3 ${j === 0 ? 'font-medium text-brand-navy' : 'text-center text-charcoal'}`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <a href="/schedule" class="btn-primary">Schedule Your Implant Denture Evaluation</a>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Implant-Supported Denture FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
