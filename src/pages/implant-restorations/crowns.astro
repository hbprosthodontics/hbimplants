---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'What is an implant crown?', answer: 'An implant crown is the visible tooth replacement that screws or cements onto the top of a dental implant abutment. It replaces the anatomical crown of the natural tooth — the part visible above the gumline. The implant post replaces the root; the crown replaces everything above.' },
  { question: 'How is an implant crown attached?', answer: 'Implant crowns are attached either with a screw (screw-retained) or dental cement (cement-retained). Screw-retained crowns are retrievable without damaging the restoration — an advantage for future maintenance. Cement-retained crowns often achieve slightly better aesthetics. Dr. Favian Cheong selects the attachment method based on the implant position, aesthetic zone, and your specific anatomy.' },
  { question: 'How long after implant placement can I get my crown?', answer: 'After implant placement, osseointegration typically takes 3–4 months. Crown placement proceeds once 3D imaging confirms the implant has fully integrated with the bone. In some cases, immediate loading protocols allow a temporary crown to be placed the same day as surgery, with the final crown placed after healing.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Implant Crowns Huntington Beach | Custom Crown for Your Dental Implant"
  description="Implant crowns in Huntington Beach designed and placed by a prosthodontist for the most natural, durable result. Call (714) 846-1386 to learn more."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Implant Crowns Huntington Beach —<br />
          <span class="text-brand-gold">Custom-Designed for a Natural Result</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">The crown is the tooth your dental implant wears. A prosthodontist-designed implant crown matches your natural teeth so precisely that even other dental professionals cannot distinguish it from a real tooth.</p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Implant Crown Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="section-heading mb-6">The Art of Implant Crown Design</h2>
      <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
        An implant crown must do three things: look like the natural tooth it's replacing, integrate seamlessly with adjacent teeth, and function correctly under bite forces. Achieving all three simultaneously requires the planning and material knowledge of a prosthodontist.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-4">
        The emergence profile — the shape of the crown as it exits the gumline — is one of the most technically critical aspects of implant crown design. A crown with improper emergence can trap bacteria at the gum interface (causing peri-implant disease), push gum tissue unnaturally (causing inflammation), or create gaps that trap food. Dr. Favian Cheong designs every emergence profile individually using digital impressions that capture the exact tissue architecture around your implant.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-6">
        Material selection is equally important. For front teeth, IPS e.max lithium disilicate provides the translucency and shade variation of natural enamel. For back teeth, monolithic zirconia offers maximum strength for heavy occlusal loads. For patients with thin gum tissue, metal-free zirconia abutments prevent dark shadows at the gum line. We select the optimal material combination for your specific tooth position, bite, and aesthetics. See <a href="/implant-restorations" class="text-brand-blue hover:underline">all implant restoration options</a> or <a href="/dental-implants" class="text-brand-blue hover:underline">learn about implant placement</a>.
      </p>
      <a href="/schedule" class="btn-primary">Schedule Your Crown Consultation</a>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Implant Crown FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
