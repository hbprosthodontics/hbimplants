---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'How does an implant bridge differ from a conventional bridge?', answer: 'A conventional dental bridge requires crowning the adjacent healthy teeth on either side of the gap to serve as anchors. This permanently damages two or more healthy teeth. An implant-supported bridge uses 2 implants as anchors — the adjacent healthy teeth are completely untouched. Implant bridges also preserve jawbone and have a longer lifespan than tooth-supported bridges.' },
  { question: 'How many implants do I need for a bridge?', answer: 'A 3-unit bridge (replacing one missing tooth) requires 2 implants — one on each end. A 4-unit bridge (replacing 2 adjacent missing teeth) also typically uses 2 implants. For longer spans (3+ adjacent missing teeth), 3 or more implants may be needed depending on bone quality and bite forces.' },
  { question: 'How long do implant-supported bridges last?', answer: 'Implant-supported bridges typically last 15–20 years or more. The implant posts are designed to last a lifetime. The bridge prosthesis may eventually need replacement due to material wear, though zirconia bridges are exceptionally durable. This significantly outlasts conventional tooth-supported bridges, which average 10–15 years.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Implant-Supported Bridges Huntington Beach, CA"
  description="Implant-supported bridges in Huntington Beach replace multiple missing teeth without grinding down healthy neighbors. Permanent, fixed, natural results."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Implant Bridges Huntington Beach —<br />
          <span class="text-brand-teal">Fixed Tooth Replacement Without Touching Healthy Teeth</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">Replace 2–4 adjacent missing teeth with a fixed bridge anchored to implants — no healthy tooth preparation required, no bone loss, no slipping.</p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Bridge Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="section-heading mb-6">Implant-Supported Bridges: The Superior Fixed Option</h2>
      <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
        When multiple adjacent teeth are missing, an implant-supported bridge is often the ideal solution. Two implants placed at either end of the gap support the bridge — eliminating the need to crown healthy neighboring teeth and preserving bone throughout the span.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-4">
        Conventional bridges have been a standard option for decades, but they come at a permanent cost: the healthy teeth adjacent to the gap must be ground down to anchor stumps. This removes healthy tooth structure that cannot be restored, creates three points of future failure (two anchor crowns and the bridge itself), and does nothing to prevent bone loss beneath the missing tooth.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-6">
        An implant-supported bridge eliminates all of these downsides. Adjacent teeth remain completely intact. The implant posts stimulate bone beneath the span. And because the bridge is anchored to implants rather than teeth, its longevity is not affected by any future changes to adjacent teeth. For more on implant options, see our <a href="/dental-implants" class="text-brand-blue hover:underline">dental implants overview</a> and <a href="/restorative-dentistry/bridges" class="text-brand-blue hover:underline">conventional bridge alternatives</a>.
      </p>
      <a href="/schedule" class="btn-primary">Schedule Your Implant Bridge Evaluation</a>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Implant Bridge FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
