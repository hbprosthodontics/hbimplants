---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'What is an implant restoration?', answer: 'An implant restoration is the prosthetic component (crown, bridge, or denture) that is attached to a dental implant post to replace the visible portion of a missing tooth. The implant post (inserted into bone) serves as the root; the restoration is the tooth itself. The quality and design of the restoration is just as important as the implant placement — a poorly designed crown on a well-placed implant still produces a poor outcome.' },
  { question: 'Can I use my existing implants and get a new restoration at Huntington Beach Prosthodontics?', answer: 'Yes. If you have existing implants that were placed elsewhere and need a new crown, bridge, or denture, we can evaluate your implants and fabricate a new restoration to fit them. We work with all major implant systems and can identify your implant brand from X-rays and components to ensure a compatible restoration.' },
  { question: 'What material is best for an implant crown?', answer: 'For implant crowns in the visible smile zone, IPS e.max lithium disilicate or PFZ (porcelain-fused-to-zirconia) provides excellent aesthetics. For back teeth (molars) with heavy bite forces, full-zirconia crowns offer maximum strength and durability. The material choice depends on the tooth\'s location in the mouth and your bite forces.' },
  { question: 'How long does an implant crown last?', answer: 'Implant crowns typically last 15–25 years. The implant post itself is designed to last a lifetime. The crown eventually wears or may chip with heavy use, at which point a new crown is fabricated and placed on the existing integrated implant — a simple process compared to the original treatment.' },
  { question: 'Do implant restorations feel natural?', answer: 'Yes. Well-designed implant restorations are indistinguishable from natural teeth in both feel and function. The emergence profile (the shape of the crown as it exits the gum line), the bite adjustment, and the shade matching all contribute to how natural the restoration feels and looks. Prosthodontist-designed restorations pay meticulous attention to all these factors.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Implant Restorations Huntington Beach | Crowns, Bridges & Implant Dentures"
  description="Implant restorations in Huntington Beach include crowns, bridges, and dentures anchored to implants. Maximum stability and natural results. Call (714) 846-1386."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Implant Restorations in Huntington Beach —<br />
          <span class="text-brand-gold">Crowns, Bridges, and Dentures on Implants</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          The restoration placed on your implant is as important as the implant itself. At Huntington Beach Prosthodontics, every implant crown, bridge, and denture is designed by Dr. Favian Cheong for a result that looks, feels, and functions like natural teeth.
        </p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Restoration Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-heading mb-6">The Restorative Side of Dental Implants</h2>
        <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
          Dental implant treatment has two critical phases: the surgical placement of the titanium post and the restorative placement of the prosthesis (crown, bridge, or denture) on top. Many patients receive excellent implant placement from an oral surgeon or periodontist, only to receive a mediocre restoration from a general dentist — resulting in poor aesthetics or bite problems that could have been avoided.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          At Huntington Beach Prosthodontics, Dr. Favian Cheong specializes in the restorative phase. Whether you had your implant placed here or elsewhere, we design and deliver implant restorations that are: precisely shaped for natural emergence profile (the way the crown exits the gum line), shade-matched to your surrounding teeth with nuance and detail, and bite-calibrated for even force distribution that protects both the implant and surrounding teeth.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-6">
          Explore the specific types of implant restorations we provide: <a href="/implant-restorations/crowns" class="text-brand-blue hover:underline">implant crowns</a> for single tooth replacement, <a href="/implant-restorations/bridges" class="text-brand-blue hover:underline">implant bridges</a> for multiple adjacent missing teeth, <a href="/implant-restorations/dentures" class="text-brand-blue hover:underline">implant-supported dentures</a> for full arch rehabilitation, and <a href="/implant-restorations/snap-on" class="text-brand-blue hover:underline">snap-on dentures</a> for the most affordable implant retention option.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            { title: 'Implant Crowns', desc: 'Single tooth restoration. Custom-designed to match adjacent teeth exactly.', href: '/implant-restorations/crowns' },
            { title: 'Implant Bridges', desc: 'Replace 2–4 adjacent missing teeth on 2 implants. No grinding of healthy teeth.', href: '/implant-restorations/bridges' },
            { title: 'Implant-Supported Dentures', desc: 'Full arch prosthesis supported by 4–6 implants. Fixed, permanent, non-removable.', href: '/implant-restorations/dentures' },
            { title: 'Snap-on Dentures', desc: 'Removable denture anchored to 2–4 implants. Dramatically more stable than conventional dentures.', href: '/implant-restorations/snap-on' },
          ].map(r => (
            <a href={r.href} class="card hover:shadow-lg hover:border-brand-blue transition-all group">
              <h3 class="font-serif text-lg font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">{r.title}</h3>
              <p class="text-neutral-mid text-sm leading-relaxed mb-2">{r.desc}</p>
              <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Implant Restoration FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
