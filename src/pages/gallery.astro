---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};
---

<BaseLayout
  title="Before & After Gallery | Huntington Beach Prosthodontics"
  description="View real patient before and after photos from Huntington Beach Prosthodontics. Dental implants, veneers, full arch restorations, and smile makeovers."
  schema={localBusiness}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Before & After Gallery
      </h1>
      <p class="text-mid-gray text-lg max-w-2xl mx-auto">
        Real results from real patients at Huntington Beach Prosthodontics. All photos shown with patient consent. Individual results may vary.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center py-16 bg-surface-2 rounded-2xl">
        <svg class="w-16 h-16 mx-auto mb-4 text-neutral-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <h2 class="font-serif text-2xl font-bold text-brand-navy mb-3">Gallery Coming Soon</h2>
        <p class="text-neutral-mid max-w-md mx-auto mb-6">
          Patient photos are being added to this gallery. In the meantime, view our results during your complimentary consultation.
        </p>
        <a href="/schedule" class="btn-primary">Schedule to See Our Work</a>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
