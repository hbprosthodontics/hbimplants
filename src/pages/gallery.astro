---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import GalleryGrid, { type GalleryImage } from '../components/GalleryGrid.astro';

// ─────────────────────────────────────────────────────────────────────────────
// ADD YOUR GALLERY IMAGES HERE
//
// 1. Copy your photos to: public/images/gallery/
// 2. Add an entry below for each photo.
//    - src:       path starting with /images/gallery/
//    - alt:       describe what's shown (important for SEO & accessibility)
//    - procedure: category label — becomes a filter button automatically
//                 e.g. "Dental Implants" | "All-on-4" | "Veneers" | "Smile Makeover"
//    - caption:   optional short text shown in the lightbox
//
// Example:
//   { src: '/images/gallery/implant-001.jpg', alt: 'Single tooth implant result', procedure: 'Dental Implants', caption: 'Single tooth implant — natural, seamless result' },
// ─────────────────────────────────────────────────────────────────────────────
const galleryImages: GalleryImage[] = [
  { src: '/images/gallery/35c233_4d53b085a2b74aba85fb77c285d3e4d2~mv2.avif', alt: 'Patient smile restoration result' },
  { src: '/images/gallery/edc2a9_24068984beb9473493ef4372362b4fe4f003.avif', alt: 'Dental restoration patient result' },
  { src: '/images/gallery/edc2a9_4ed4380f54574560a2b7ceeb4b7ce2d2f003.avif', alt: 'Smile transformation at Huntington Beach Prosthodontics' },
  { src: '/images/gallery/edc2a9_63f959b1683a47f9b5fb4916473d5811~mv2.avif', alt: 'Prosthodontic treatment result' },
  { src: '/images/gallery/edc2a9_6a7fa9255fa54effae65db782655fae5~mv2.avif', alt: 'Patient dental restoration outcome' },
  { src: '/images/gallery/edc2a9_8263132f76fb43e0aa24b5ddb546dde5~mv2.avif', alt: 'Full smile makeover result' },
  { src: '/images/gallery/edc2a9_bf872454f2f4482a8b3ebd4a4e1cf8b1~mv2.avif', alt: 'Cosmetic dentistry patient result' },
  { src: '/images/gallery/edc2a9_d6d0537233e44b318c487d8f31e1d46b~mv2.avif', alt: 'Implant restoration patient result' },
  { src: '/images/gallery/edc2a9_f4b39cbd01d24b449cba3be2c75552f4~mv2.avif', alt: 'Patient smile improvement result' },
];

const imageGallery = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  'name': 'Patient Results Gallery — Huntington Beach Prosthodontics',
  'description': 'Before and after photos of dental implant, veneer, and smile restoration patients treated at Huntington Beach Prosthodontics.',
  'url': 'https://hbimplants.com/gallery',
  'author': {
    '@type': 'Organization',
    'name': 'Huntington Beach Prosthodontics',
    'url': 'https://hbimplants.com',
  },
};

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};
---

<BaseLayout
  title="Before & After Gallery | Huntington Beach Prosthodontics"
  description="View real patient result photos from Huntington Beach Prosthodontics. Dental implants, veneers, full arch restorations, and smile makeovers."
  schema={[localBusiness, imageGallery]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Patient Gallery
      </h1>
      <p class="text-mid-gray text-lg max-w-2xl mx-auto">
        Real results from real patients at Huntington Beach Prosthodontics. All photos shown with patient consent. Individual results may vary.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {galleryImages.length > 0 ? (
        <GalleryGrid images={galleryImages} heading="Our Work" />
      ) : (
        <div class="text-center py-16 bg-surface-2 rounded-2xl">
          <svg class="w-16 h-16 mx-auto mb-4 text-neutral-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <h2 class="font-serif text-2xl font-bold text-brand-navy mb-3">Gallery Coming Soon</h2>
          <p class="text-neutral-mid max-w-md mx-auto mb-6">
            Patient photos are being added to this gallery. In the meantime, view our results during your complimentary consultation.
          </p>
          <a href="/schedule" class="btn-primary">Schedule to See Our Work</a>
        </div>
      )}
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
