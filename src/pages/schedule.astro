---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQBlock from '../components/FAQBlock.astro';

import { localBusinessSchema as localBusiness, site, address, hours } from '../config/site';

const contactPoint = {
  '@context': 'https://schema.org',
  '@type': 'ContactPoint',
  'contactType': 'customer service',
  'telephone': site.phone,
  'areaServed': ['Huntington Beach', 'Fountain Valley', 'Costa Mesa', 'Newport Beach', 'Seal Beach'],
  'availableLanguage': 'English',
  'hoursAvailable': [
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': 'Monday', 'opens': '09:00', 'closes': '17:00' },
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': 'Wednesday', 'opens': '09:00', 'closes': '17:00' },
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': 'Thursday', 'opens': '09:00', 'closes': '17:00' },
    { '@type': 'OpeningHoursSpecification', 'dayOfWeek': 'Friday', 'opens': '09:00', 'closes': '17:00' },
  ],
};

const faqs = [
  {
    question: 'Do you accept new patients?',
    answer: `Yes — we are actively welcoming new patients. We offer a consultation for dental implants and major restorative procedures. Call us at ${site.phone} or book online.`,
  },
  {
    question: 'What should I bring to my first appointment?',
    answer: 'Please bring a valid photo ID, your dental insurance card (if applicable), a list of current medications, and any recent dental X-rays or records from your previous dentist. If you\'ve had imaging done recently, having it on hand can save time and avoid repeating tests unnecessarily.',
  },
  {
    question: 'How long does the first visit take?',
    answer: 'New patient consultations are typically 60 to 90 minutes. This allows time for a thorough examination, complete digital records, and an unhurried conversation about your goals and treatment options. Complex cases may require slightly more time.',
  },
  {
    question: 'How soon can I get an appointment?',
    answer: `We typically see new patients within a few days to a week. For the fastest scheduling, call us directly at ${site.phone} or book online.`,
  },
  {
    question: 'What if I need to cancel or reschedule?',
    answer: `We understand that life happens. Please call us at least 24 hours in advance so we can offer your time slot to another patient who may be waiting. You can reach us at ${site.phone} during office hours.`,
  },
  {
    question: 'Do you accept dental insurance?',
    answer: 'Yes. We accept most major dental insurance plans. Our team will verify your coverage and provide a clear breakdown of your estimated out-of-pocket costs before treatment begins. We also offer flexible financing options for procedures not fully covered by insurance.',
  },
];
---

<BaseLayout
  title="Schedule an Appointment | Huntington Beach Prosthodontics"
  description="Book an appointment with our Huntington Beach prosthodontist. Dental implants, veneers, dentures, and smile makeovers. Most insurance accepted."
  schema={[localBusiness, contactPoint]}
>
  <!-- Hero -->
  <section class="bg-surface-2 py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Schedule Your Appointment
      </h1>
      <p class="text-charcoal text-lg max-w-2xl mx-auto">
        Book online or call us directly at <a href={`tel:${site.phoneDigits}`} class="text-brand-teal font-semibold hover:underline">{site.phone}</a>.
      </p>
    </div>
  </section>

  <!-- Book or Call -->
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-lg border border-neutral-border p-8 md:p-10">
        <h2 class="font-serif text-2xl font-bold text-brand-navy mb-2">How would you like to schedule?</h2>
        <p class="text-charcoal mb-8">Choose the option that works best for you.</p>

        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href={site.bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-center text-base py-4 font-semibold flex-1"
          >
            Book Online
          </a>
          <a
            href={`tel:${site.phoneDigits}`}
            class="btn-secondary text-center text-base py-4 font-semibold flex-1"
          >
            Call {site.phone}
          </a>
        </div>

        <p class="text-sm text-charcoal text-center">
          Online booking opens in a new tab. For the fastest scheduling, call us during office hours.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="text-center p-4 bg-surface-2 rounded-xl">
          <div class="font-semibold text-brand-navy mb-1">Phone</div>
          <a href={`tel:${site.phoneDigits}`} class="text-brand-teal text-sm hover:underline">{site.phone}</a>
        </div>
        <div class="text-center p-4 bg-surface-2 rounded-xl">
          <div class="font-semibold text-brand-navy mb-1">Address</div>
          <div class="text-charcoal text-sm">{address.street}<br />{address.city}, {address.state}</div>
        </div>
        <div class="text-center p-4 bg-surface-2 rounded-xl">
          <div class="font-semibold text-brand-navy mb-1">Hours</div>
          <div class="text-charcoal text-sm">
            {hours.display.map((h) => `${h.day}: ${h.time}`).join(' · ')}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Appointment & First Visit FAQ" />
    </div>
  </section>

  <!-- Map -->
  <section class="pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl overflow-hidden border border-neutral-border h-64 md:h-80">
        <iframe
          src="https://maps.google.com/maps?q=16141+Bolsa+Chica+St+Suite+C,+Huntington+Beach,+CA+92649&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Huntington Beach Prosthodontics location map"
        ></iframe>
      </div>
      <div class="mt-3 text-center">
        <a href="https://share.google/HnGTXT5RBHoUzW0kE" target="_blank" rel="noopener noreferrer" class="text-sm text-brand-blue hover:underline">
          Get directions →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
