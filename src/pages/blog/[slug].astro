---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTABlock from '../../components/CTABlock.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'headline': post.data.title,
  'description': post.data.description,
  'datePublished': post.data.publishDate.toISOString(),
  'dateModified': (post.data.updatedDate || post.data.publishDate).toISOString(),
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': `https://hbimplants.com/blog/${post.slug}`,
  },
  'url': `https://hbimplants.com/blog/${post.slug}`,
  'author': {
    '@type': 'Organization',
    'name': post.data.author,
    'url': 'https://hbimplants.com',
  },
  'publisher': {
    '@type': 'Organization',
    'name': 'Huntington Beach Prosthodontics',
    'url': 'https://hbimplants.com',
    'logo': {
      '@type': 'ImageObject',
      'url': 'https://hbimplants.com/images/og-default.jpg',
    },
  },
  ...(post.data.featuredImage ? { 'image': `https://hbimplants.com${post.data.featuredImage}` } : {}),
  'keywords': post.data.targetKeyword,
};

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};

const faqSchema = post.data.faqs ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': post.data.faqs.map(f => ({
    '@type': 'Question',
    'name': f.question,
    'acceptedAnswer': { '@type': 'Answer', 'text': f.answer },
  })),
} : null;

const schemas = [localBusiness, articleSchema, ...(faqSchema ? [faqSchema] : [])];

// Only include H2s in the TOC (top-level sections)
const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.featuredImage}
  ogType="article"
  articleAuthor={post.data.author}
  articleDate={post.data.publishDate.toISOString().split('T')[0]}
  schema={schemas}
>
  <!-- Breadcrumb -->
  <nav class="bg-brand-light border-b border-neutral-border py-3">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-neutral-mid">
        <li><a href="/" class="hover:text-brand-blue transition-colors">Home</a></li>
        <li class="text-neutral-border">/</li>
        <li><a href="/blog" class="hover:text-brand-blue transition-colors">Blog</a></li>
        <li class="text-neutral-border">/</li>
        <li class="text-brand-navy font-medium truncate">{post.data.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Article Header -->
  <header class="bg-white py-12 md:py-16 border-b border-neutral-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-xs text-brand-blue font-semibold uppercase tracking-wide mb-3">
        {post.data.category.replace(/-/g, ' ')}
      </div>
      <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-brand-navy mb-6 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-neutral-mid">
        <span>By {post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.publishDate.toISOString()}>
          {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>Updated {post.data.updatedDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          </>
        )}
      </div>
    </div>
  </header>

  <!-- Article Content -->
  <article class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {post.data.featuredImage && (
        <div class="mb-8 rounded-xl overflow-hidden">
          <img
            src={post.data.featuredImage}
            alt={post.data.featuredImageAlt || post.data.title}
            width="800"
            height="450"
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto"
          />
        </div>
      )}

      <!-- Table of Contents -->
      {tocHeadings.length >= 3 && (
        <nav aria-label="Table of contents" class="mb-10 rounded-xl border border-neutral-border bg-brand-light p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-neutral-mid mb-3">In This Article</p>
          <ol class="space-y-2">
            {tocHeadings.map((h, i) => (
              <li class="flex items-start gap-2 text-sm">
                <span class="text-brand-blue font-semibold flex-shrink-0">{i + 1}.</span>
                <a href={`#${h.slug}`} class="text-brand-blue hover:underline leading-snug">{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <div class="prose-dental max-w-none">
        <Content />
      </div>

      <!-- FAQ Section (if defined in frontmatter) -->
      {post.data.faqs && (
        <div class="mt-12 border-t border-neutral-border pt-10">
          <h2 class="font-serif text-2xl font-bold text-brand-navy mb-6">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {post.data.faqs.map(faq => (
              <details class="border border-neutral-border rounded-lg p-5 group">
                <summary class="font-semibold text-brand-navy cursor-pointer list-none flex justify-between items-center gap-4">
                  {faq.question}
                  <svg class="w-4 h-4 flex-shrink-0 text-neutral-mid group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <p class="mt-3 text-neutral-mid leading-relaxed">{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>

  <!-- CTA -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
