---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTABlock from '../../components/CTABlock.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// Collect all unique tags, sorted alphabetically
const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags || []))].sort();

import { localBusinessSchema as localBusiness } from '../../config/site';
---

<BaseLayout
  title="Blog | Huntington Beach Prosthodontics"
  description="Learn about dental implants, veneers, dentures, and prosthodontic care from the experts at Huntington Beach Prosthodontics. Evidence-based patient education."
  schema={localBusiness}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class="text-brand-teal text-sm font-semibold uppercase tracking-wide mb-3">Patient Education</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4 text-charcoal">
          Blog
        </h1>
        <p class="text-charcoal text-lg max-w-2xl mx-auto">
          Expert insight on dental implants, full-arch restorations, veneers, and prosthodontic care.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16 text-charcoal">
          <p>Blog posts coming soon. Check back shortly.</p>
        </div>
      ) : (
        <>
          <div class="flex flex-col lg:flex-row gap-8 lg:gap-8">
            <div class="lg:flex-1 min-w-0 order-2 lg:order-1">
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
                {sortedPosts.map((post) => (
                  <a
                href={`/blog/${post.slug}`}
                    class="blog-card card hover:shadow-lg hover:border-brand-teal transition-all duration-200 group"
                    data-tags={(post.data.tags || []).join(' ')}
                  >
                    {post.data.featuredImage && (
                      <div class="aspect-video bg-surface-2 rounded-lg overflow-hidden mb-4">
                        <img
                          src={post.data.featuredImage}
                          alt={post.data.featuredImageAlt || post.data.title}
                          width="400"
                          height="225"
                          loading="lazy"
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      </div>
                    )}
                    <div class="mb-3 min-h-[2.75rem]">
                      <div class="text-[10px] font-semibold uppercase tracking-wider text-brand-teal mb-1.5">
                        {post.data.category.replace(/-/g, ' ')}
                      </div>
                      <div class="flex flex-nowrap gap-1.5 overflow-hidden">
                        {post.data.tags?.slice(0, 3).map((t: string) => (
                          <span class="inline-flex items-center justify-center shrink-0 rounded-full px-2 py-0.5 text-[10px] font-medium bg-brand-teal/10 text-brand-teal border border-brand-teal/20">{t.replace(/-/g, ' ')}</span>
                        ))}
                      </div>
                    </div>
                    <h2 class="font-serif text-lg font-semibold text-charcoal mb-2 group-hover:text-brand-teal transition-colors leading-tight">
                      {post.data.title}
                    </h2>
                    <p class="text-charcoal text-sm leading-relaxed mb-4">{post.data.description}</p>
                    <div class="flex items-center justify-between text-xs text-neutral-mid">
                      <span>{post.data.author}</span>
                      <span>{post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                    </div>
                  </a>
                ))}
              </div>
              <p id="blog-no-results" class="hidden text-center py-16 text-charcoal">
                No posts match this filter. Try a different tag.
              </p>
            </div>
            <aside class="lg:w-auto shrink-0 order-1 lg:order-2 lg:flex lg:justify-end lg:items-start">
              <div class="lg:sticky lg:top-24 lg:text-right w-full lg:w-auto" id="blog-tags">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-mid-gray mb-3">Filter</h3>
                <div class="flex flex-wrap lg:flex-col lg:items-end gap-1.5">
                  <button
                    type="button"
                    data-tag=""
                    class="blog-tag active px-2.5 py-1 rounded-full text-xs font-medium transition-colors bg-charcoal text-white hover:bg-brand-teal w-fit"
                  >
                    All
                  </button>
                  {allTags.map((tag) => (
                    <button
                      type="button"
                      data-tag={tag}
                      class="blog-tag px-2.5 py-1 rounded-full text-xs font-medium transition-colors border border-border-light bg-white text-mid-gray hover:border-brand-teal/50 hover:text-brand-teal w-fit"
                    >
                      {tag.replace(/-/g, ' ')}
                    </button>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </>
      )}
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.blog-tag').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag') || '';
      document.querySelectorAll('.blog-tag').forEach((b) => {
        b.classList.remove('active', 'bg-charcoal', 'text-white');
        b.classList.add('border', 'border-border-light', 'bg-white', 'text-mid-gray');
      });
      btn.classList.add('active', 'bg-charcoal', 'text-white');
      btn.classList.remove('border', 'border-border-light', 'bg-white', 'text-mid-gray');

      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('blog-no-results');
      let visible = 0;
      cards.forEach((card) => {
        const tags = (card.getAttribute('data-tags') || '').split(' ').filter(Boolean);
        const show = !tag || tags.includes(tag);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
