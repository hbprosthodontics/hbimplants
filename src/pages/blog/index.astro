---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CTABlock from '../../components/CTABlock.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// Collect all unique tags, sorted alphabetically
const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags || []))].sort();

import { localBusinessSchema as localBusiness } from '../../config/site';
---

<BaseLayout
  title="Patient Education Blog | Huntington Beach Prosthodontics"
  description="Learn about dental implants, veneers, dentures, and prosthodontic care from the experts at Huntington Beach Prosthodontics. Evidence-based patient education."
  schema={localBusiness}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
          Patient Education Blog
        </h1>
        <p class="text-mid-gray text-lg max-w-2xl mx-auto">
          Expert insight on dental implants, full-arch restorations, veneers, and prosthodontic care — written by specialists, for patients.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16 text-neutral-mid">
          <p>Blog posts coming soon. Check back shortly.</p>
        </div>
      ) : (
        <>
          <div class="flex flex-wrap items-center gap-1.5 mb-6" id="blog-tags">
            <span class="text-xs font-medium text-mid-gray mr-1">Filter:</span>
            <button
              type="button"
              data-tag=""
              class="blog-tag active px-2.5 py-1 rounded-md text-xs font-medium transition-colors bg-charcoal text-white hover:bg-brand-teal"
            >
              All
            </button>
            {allTags.map((tag) => (
              <button
                type="button"
                data-tag={tag}
                class="blog-tag px-2.5 py-1 rounded-md text-xs font-medium transition-colors border border-border-light bg-white text-mid-gray hover:border-charcoal/30 hover:text-charcoal"
              >
                {tag.replace(/-/g, ' ')}
              </button>
            ))}
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="blog-grid">
            {sortedPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="blog-card card hover:shadow-lg hover:border-brand-blue transition-all duration-200 group"
                data-tags={(post.data.tags || []).join(' ')}
              >
                {post.data.featuredImage && (
                  <div class="aspect-video bg-surface-2 rounded-lg overflow-hidden mb-4">
                    <img
                      src={post.data.featuredImage}
                      alt={post.data.featuredImageAlt || post.data.title}
                      width="400"
                      height="225"
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                <div class="flex flex-wrap gap-2 mb-2">
                  {post.data.tags?.slice(0, 3).map((t: string) => (
                    <span class="text-[10px] rounded px-2 py-0.5 bg-surface-2 text-mid-gray">{t.replace(/-/g, ' ')}</span>
                  ))}
                </div>
                <div class="text-xs text-brand-blue font-semibold uppercase tracking-wide mb-2">
                  {post.data.category.replace('-', ' ')}
                </div>
                <h2 class="font-serif text-lg font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors leading-tight">
                  {post.data.title}
                </h2>
                <p class="text-neutral-mid text-sm leading-relaxed mb-4">{post.data.description}</p>
                <div class="flex items-center justify-between text-xs text-neutral-mid">
                  <span>{post.data.author}</span>
                  <span>{post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                </div>
              </a>
            ))}
          </div>
          <p id="blog-no-results" class="hidden text-center py-16 text-mid-gray">
            No posts match this filter. Try a different tag.
          </p>
        </>
      )}
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.blog-tag').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag') || '';
      document.querySelectorAll('.blog-tag').forEach((b) => {
        b.classList.remove('active', 'bg-charcoal', 'text-white');
        b.classList.add('border', 'border-border-light', 'bg-white', 'text-mid-gray');
      });
      btn.classList.add('active', 'bg-charcoal', 'text-white');
      btn.classList.remove('border', 'border-border-light', 'bg-white', 'text-mid-gray');

      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('blog-no-results');
      let visible = 0;
      cards.forEach((card) => {
        const tags = (card.getAttribute('data-tags') || '').split(' ').filter(Boolean);
        const show = !tag || tags.includes(tag);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
