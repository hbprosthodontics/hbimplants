---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'What does restorative dentistry include?', answer: 'Restorative dentistry encompasses all procedures that repair, replace, or rehabilitate damaged or missing teeth. At Huntington Beach Prosthodontics, restorative services include dental crowns (covering damaged or weakened teeth), dental bridges (replacing one or more missing teeth using adjacent teeth as anchors), inlays and onlays (partial crowns for back teeth), full mouth reconstruction, and all implant-based restorations. The goal is to restore function, comfort, and aesthetics.' },
  { question: 'What is the difference between a prosthodontist and a restorative dentist?', answer: 'All prosthodontists are restorative dentists, but not all restorative dentists are prosthodontists. Prosthodontics is a recognized dental specialty requiring an additional 3 years of graduate-level training beyond dental school, focused exclusively on restoring and replacing teeth. General dentists who perform restorative procedures have foundational training in these techniques. A prosthodontist has specialist-level expertise, particularly for complex cases requiring full mouth rehabilitation, implant restorations, and esthetic reconstruction.' },
  { question: 'How long do dental crowns last?', answer: 'Modern all-ceramic crowns (IPS e.max lithium disilicate, zirconia) typically last 15–25 years with proper care. The longevity depends on the material, the quality of the cementation, oral hygiene, and bite forces. Crowns on posterior (back) teeth experience heavier forces and may have shorter lifespans than those on anterior (front) teeth. Regular check-ups allow early detection of any issues before they compromise the crown.' },
  { question: 'When is a dental bridge appropriate versus a dental implant?', answer: 'A dental bridge is appropriate when: implant surgery is not medically feasible, the adjacent teeth already need crowns for other reasons, or cost constraints make implants impractical. A dental implant is generally preferred when: adjacent teeth are healthy (a bridge would require permanently grinding them down), there is sufficient bone, and the patient is a suitable surgical candidate. Implants do not accelerate bone loss and do not involve neighboring teeth, making them the superior long-term solution in most cases.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Restorative Dentistry Huntington Beach | Crowns & Bridges"
  description="Restorative dentistry in Huntington Beach by a prosthodontist. Crowns, bridges, and complex full mouth rehabilitation with specialist-level precision."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Restorative Dentistry Huntington Beach —<br />
          <span class="text-brand-teal">Repair, Rebuild, and Rehabilitate Your Smile</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          From a single damaged tooth to complete mouth rehabilitation, Huntington Beach Prosthodontics restores teeth with specialist-level precision. Dr. Favian Cheong applies 3+ years of post-doctoral prosthodontic training to every restoration — whether a single crown or a full-arch rebuild.
        </p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule a Restorative Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-heading mb-6">Prosthodontic Restorative Care</h2>
        <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
          Prosthodontics — the dental specialty practiced at Huntington Beach Prosthodontics — is defined by its focus on the restoration and replacement of teeth. Every aspect of Dr. Favian Cheong's three-year specialty residency was devoted to mastering the science and art of restorative dentistry at the highest level. This specialist training makes a measurable difference in outcomes, particularly for patients with complex or demanding cases.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          Restorative dentistry addresses teeth that have been damaged by decay, fracture, wear, or injury, as well as teeth that are missing. The objective is always the same: restore the tooth (or teeth) to their natural form, function, and appearance as completely as possible, using materials and techniques that maximize longevity and minimize future complications.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-8">
          We offer the full spectrum of restorative procedures, from straightforward single-tooth crowns to complex multi-quadrant rebuilds requiring careful sequencing and material selection. For patients with extensively damaged dentitions, full mouth rehabilitation restores all teeth systematically — addressing bite alignment, tooth structure, and aesthetics as a unified plan rather than treating teeth one at a time.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            { title: 'Dental Crowns', desc: 'Cap a damaged, weakened, or root-canal-treated tooth with a ceramic or zirconia crown. Restores full function and natural appearance.', href: '/restorative-dentistry/crowns' },
            { title: 'Dental Bridges', desc: 'Replace one or more missing teeth using the adjacent teeth as anchors. A fixed, non-removable restoration without implants.', href: '/restorative-dentistry/bridges' },
            { title: 'Implant Restorations', desc: 'Crowns, bridges, and dentures anchored to dental implants. The most durable, natural tooth replacement option.', href: '/implant-restorations' },
            { title: 'Full Mouth Reconstruction', desc: 'Comprehensive rehabilitation of all teeth for patients with severe wear, multiple missing teeth, or complex bite issues.', href: '/all-on-x/full-mouth-reconstruction' },
          ].map(r => (
            <a href={r.href} class="card hover:shadow-lg hover:border-brand-blue transition-all group">
              <h3 class="font-serif text-lg font-semibold text-brand-navy mb-2 group-hover:text-brand-blue transition-colors">{r.title}</h3>
              <p class="text-neutral-mid text-sm leading-relaxed mb-2">{r.desc}</p>
              <span class="text-brand-blue text-sm font-semibold">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Restorative Dentistry FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
