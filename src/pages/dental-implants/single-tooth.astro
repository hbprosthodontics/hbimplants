---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = {
  '@context': 'https://schema.org', '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics',
};
const procedureSchema = {
  '@context': 'https://schema.org', '@type': 'MedicalProcedure',
  'name': 'Single Tooth Dental Implant',
  'description': 'A single tooth dental implant replaces one missing tooth with a titanium post and custom crown, preserving adjacent teeth and jawbone without requiring a dental bridge.',
  'procedureType': 'https://schema.org/TherapeuticProcedure', 'bodyLocation': 'Mouth',
  'followup': 'As recommended by your prosthodontist',
};
const faqs = [
  { question: 'How is a single tooth implant different from a dental bridge?', answer: 'A bridge requires grinding down the two adjacent healthy teeth to serve as anchors. A single tooth implant stands completely independently — no neighboring teeth are touched. This preserves your healthy tooth structure, eliminates the risk of decay under bridge crowns, and maintains the jawbone where the tooth was lost. Implants are the superior long-term solution for single tooth replacement in virtually every clinical situation.' },
  { question: 'How long does the single tooth implant process take?', answer: 'From consultation to final crown, expect 4–6 months for a straightforward single tooth implant without bone grafting. The implant placement surgery itself takes about 1 hour. The 3–4 month healing period (osseointegration) is the longest phase — once the implant has integrated, crown placement typically takes 2–3 weeks from impression to final placement.' },
  { question: 'Will my implant crown look natural?', answer: 'Yes. The crown placed on your single tooth implant is custom-made from high-quality porcelain or zirconia and shade-matched to your surrounding teeth. At Huntington Beach Prosthodontics, Dr. Favian Cheong designs each crown with meticulous attention to shape, shade, and texture to achieve a completely natural appearance that only a trained eye can distinguish from your natural teeth.' },
  { question: 'Does the single tooth implant procedure hurt?', answer: 'The surgery is performed under local anesthesia. You will feel pressure during placement but should not experience pain. Post-operative discomfort is typically mild — comparable to a tooth extraction — and most patients manage it with over-the-counter ibuprofen. Most people return to work the following day.' },
  { question: 'What happens if I don\'t replace my missing tooth?', answer: 'When a tooth is lost, the jawbone underneath begins to resorb (shrink) because it no longer receives stimulation from a tooth root. Over 1–3 years, this bone loss can become significant, causing adjacent teeth to shift, alter your bite, change your facial appearance, and make future implant placement more difficult or impossible without bone grafting. The sooner you replace a missing tooth with an implant, the simpler and less costly the process.' },
  { question: 'Is a single tooth implant covered by insurance?', answer: 'Many dental insurance plans now cover a portion of implant costs. Coverage varies widely by plan. We verify your benefits before treatment and provide a clear breakdown of what your insurance will cover and what your out-of-pocket cost will be. We also offer financing options for the patient-responsible balance.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Single Tooth Implant Huntington Beach | Replace One Missing Tooth"
  description="Replace a single missing tooth with a permanent dental implant in Huntington Beach. Natural look and feel. Specialist care from Dr. Favian Cheong. Call (714) 846-1386."
  schema={[localBusiness, procedureSchema, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-3">Dental Implants › Single Tooth</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Single Tooth Implant in Huntington Beach —<br />
          <span class="text-brand-gold">Replace a Missing Tooth Permanently</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          A single tooth implant is the gold-standard solution for replacing one missing tooth — preserving adjacent teeth, maintaining jawbone, and restoring full function with a natural-looking crown.
        </p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-heading mb-6">The Best Way to Replace a Single Missing Tooth</h2>
        <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
          When a single tooth is lost — whether to decay, trauma, or extraction — you have three replacement options: a dental bridge, a removable partial denture, or a single tooth implant. Of the three, only the implant replaces the tooth root itself and delivers outcomes that are genuinely indistinguishable from a natural tooth in both function and aesthetics.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          A traditional bridge requires grinding down the two adjacent healthy teeth to create anchor points. This permanently damages two natural teeth to replace one lost tooth — a tradeoff that many patients later regret. A single tooth implant stands completely independently, anchored in the jawbone with no involvement from neighboring teeth. Your healthy teeth stay healthy.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-6">
          Beyond tooth preservation, the implant does something a bridge and denture cannot: it stimulates the jawbone. When a tooth root is absent, the bone underneath begins to resorb. Within 1–3 years after extraction, measurable bone loss occurs. An implant halts this process entirely by transmitting bite forces directly into the bone — exactly as a natural root does. If you're considering a <a href="/dental-implants/consultation" class="text-brand-blue hover:underline">dental implant consultation</a> in Huntington Beach, the earlier you act, the simpler and less costly the process.
        </p>

        <h2 class="section-subheading mt-10 mb-6">What to Expect: Single Tooth Implant Process</h2>
        <div class="space-y-6">
          {[
            { phase: 'Consultation & CBCT Imaging', detail: 'Dr. Favian Cheong evaluates your jawbone volume, gum health, and bite. A 3D CBCT X-ray maps the exact implant site including bone depth, nerve location, and sinus anatomy. This data drives the surgical plan.' },
            { phase: 'Implant Placement Surgery', detail: 'Under local anesthesia, a small titanium post is placed precisely into the jawbone. The gum is sutured closed. A temporary crown or healing cap is fitted. The procedure takes 45–90 minutes, and most patients feel minimal post-operative discomfort.' },
            { phase: 'Osseointegration (3–4 Months)', detail: 'The implant integrates with the surrounding bone. You will have a check X-ray at 12 weeks to confirm integration. During this period, you can eat normally with minor precautions.' },
            { phase: 'Crown Placement', detail: 'A digital scan or impression captures the integrated implant\'s position. Your custom crown is fabricated to match your adjacent teeth in color, shape, and contour. At your final appointment, the crown is secured — your new tooth is complete.' },
          ].map((step, i) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold text-sm">{i + 1}</div>
              <div>
                <h3 class="font-semibold text-brand-navy mb-1">{step.phase}</h3>
                <p class="text-neutral-mid text-sm leading-relaxed">{step.detail}</p>
              </div>
            </div>
          ))}
        </div>

        <h2 class="section-subheading mt-10 mb-4">Implant Crown Options</h2>
        <p class="text-neutral-mid leading-relaxed mb-4">
          The crown is the visible part of your implant restoration. At Huntington Beach Prosthodontics, we design every <a href="/implant-restorations/crowns" class="text-brand-blue hover:underline">implant crown</a> using high-quality materials: full-zirconia for durability, porcelain-fused-to-zirconia for aesthetics in visible areas, or IPS e.max lithium disilicate for maximum translucency in the smile zone. The material selected is based on your bite forces, the tooth position, and your aesthetic goals.
        </p>

        <h2 class="section-subheading mt-10 mb-4">Cost & Insurance for Single Tooth Implants in Huntington Beach</h2>
        <p class="text-neutral-mid leading-relaxed mb-6">
          A single tooth implant including post, abutment, and crown typically ranges from $3,500–$6,000 in the Huntington Beach area. If bone grafting is required, there is an additional fee. We provide an itemized estimate after 3D imaging so you know the complete cost before committing to treatment. Many insurance plans cover a portion, and flexible financing is available.
        </p>
        <a href="/dental-implants" class="text-brand-blue hover:underline font-semibold">← Back to Dental Implants Overview</a>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Single Tooth Implant FAQ" />
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
