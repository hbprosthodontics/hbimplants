---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

import { localBusinessSchema as localBusiness } from '../../config/site';
const faqs = [
  { question: 'What happens at my dental implant consultation?', answer: 'Your consultation includes a review of your medical and dental history, an oral examination, a 3D CBCT scan of your jaw (if not done recently), and a detailed discussion of your tooth replacement options. Dr. Favian Cheong will explain your candidacy, any preparatory steps like bone grafting, the full treatment timeline, and the expected investment. You will leave with a clear written treatment plan.' },
  { question: 'Is the implant consultation free?', answer: 'Yes — initial consultations at Huntington Beach Prosthodontics are complimentary for implant patients. The 3D CBCT scan may have a separate fee depending on your insurance coverage. We confirm any fees with you before the appointment.' },
  { question: 'Do I need a referral from my dentist to see a prosthodontist?', answer: 'No referral is needed. You can call or request an appointment directly through our website. Many of our patients self-refer after researching dental implants online. We coordinate with your general dentist after treatment as needed.' },
  { question: 'How do I prepare for my implant consultation?', answer: 'Bring your dental insurance card, a list of current medications (including supplements), and any recent dental X-rays if available. If you have dentures, bring them so we can evaluate fit and aesthetics. If you have specific concerns or questions, write them down so you don\'t forget during your appointment.' },
  { question: 'What if I\'ve been told I can\'t have implants?', answer: 'A surprising number of patients who were told they "can\'t have implants" elsewhere are actually excellent candidates — sometimes with preparatory bone grafting, sometimes with different implant approaches like All-on-4 that use bone at a different angle. 3D CBCT imaging often reveals viable bone that a 2D X-ray missed. Don\'t accept a second-hand determination — come in for a specialist evaluation.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Dental Implant Consultation Huntington Beach, CA"
  description="Schedule your free dental implant consultation in Huntington Beach. Get a personalized implant plan from Dr. Favian Cheong, certified prosthodontic specialist."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Free Dental Implant Consultation<br />
          <span class="text-brand-teal">in Huntington Beach, CA</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          Get a comprehensive, no-obligation evaluation from Dr. Favian Cheong, certified prosthodontic specialist. You'll leave with a clear treatment plan, timeline, and investment summary — no pressure, no guesswork.
        </p>
        <a href="/schedule" class="btn-accent text-base px-8 py-4 font-semibold">Book Free Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="section-heading mb-6">What's Included in Your Implant Consultation</h2>
          <div class="space-y-4">
            {[
              { title: '3D CBCT Scan Analysis', desc: 'We analyze your jawbone volume, bone density, nerve pathways, and sinus anatomy to determine implant feasibility and plan precise placement.' },
              { title: 'Comprehensive Oral Exam', desc: 'Dr. Favian Cheong evaluates your gum health, remaining teeth, bite relationship, and overall oral health as it relates to implant success.' },
              { title: 'Customized Treatment Plan', desc: 'You receive a written treatment plan including all procedures, their sequence, and timing — from bone grafting (if needed) through final crown placement.' },
              { title: 'Transparent Fee Estimate', desc: 'We provide an itemized cost breakdown and review your insurance benefits so you know exactly what to expect financially before committing.' },
              { title: 'Q&A with the Specialist', desc: 'Bring every question you have. Dr. Favian Cheong takes time to address your concerns thoroughly, because informed patients make better decisions and have better outcomes.' },
            ].map(item => (
              <div class="flex gap-4">
                <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <div class="font-semibold text-brand-navy mb-1">{item.title}</div>
                  <p class="text-neutral-mid text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-surface-2 rounded-2xl p-8">
          <h3 class="font-serif text-2xl font-semibold text-brand-navy mb-6">Who Should Schedule a Consultation?</h3>
          <ul class="space-y-3 text-neutral-mid">
            {[
              'You are missing one or more teeth',
              'You have a tooth that needs extraction',
              'Your dentures are uncomfortable or unstable',
              'You want to explore alternatives to a bridge',
              'You were told you "can\'t have implants" and want a second opinion',
              'You want to understand if All-on-4 is right for you',
              'You have failing teeth and want a long-term plan',
            ].map(item => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-brand-blue flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/schedule" class="block text-center btn-primary">Book Free Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Implant Consultation FAQ" />
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock heading="Your Free Consultation Awaits" subheading="No obligation, no pressure — just expert answers to your questions and a clear path forward for your smile." /></div>
  </section>
</BaseLayout>
