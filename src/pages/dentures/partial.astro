---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const faqs = [
  { question: 'Are partial dentures better than bridges?', answer: 'Neither is universally better — the right choice depends on your specific situation. A fixed bridge (conventional or implant-supported) is generally preferred when it is feasible, because it does not require removal, is more stable, and does not put clasping pressure on adjacent teeth. A partial denture is appropriate when multiple teeth are missing in different areas of the arch, when a bridge is not feasible due to lack of suitable anchor teeth, or when budget is the primary constraint.' },
  { question: 'How do partial dentures attach?', answer: 'The most common partial denture uses metal clasps (most often cobalt-chrome) that wrap around adjacent teeth for retention. Precision attachment partials use internal attachments within crowns on the anchor teeth — more esthetic and more stable, but requiring crown fabrication. Flexible nylon partials (like Valplast) use tooth-colored acrylic clasps that are esthetic and comfortable but less rigid.' },
  { question: 'Will people notice my partial denture?', answer: 'A well-designed partial denture should not be obvious. Metal clasps may be visible on visible teeth, which is why precision attachment or flexible partial designs are sometimes preferred for high-visibility areas. Dr. Favian Cheong designs partials to minimize any visible metal where aesthetics matter.' },
  { question: 'Can a partial denture prevent teeth from shifting?', answer: 'Yes — filling the gap left by missing teeth with a partial denture prevents adjacent and opposing teeth from drifting into the open space. Tooth shifting after loss is a real and often rapid phenomenon that can disrupt bite alignment and create issues that are difficult and expensive to correct later.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Partial Dentures Huntington Beach | Removable Partial Denture HB"
  description="Partial dentures in Huntington Beach fill gaps from multiple missing teeth. Comfortable, natural-looking partial dentures custom-made by our prosthodontist."
  schema={[localBusiness, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">
          Partial Dentures Huntington Beach —<br />
          <span class="text-brand-gold">Replace Multiple Missing Teeth Comfortably</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">Partial dentures fill gaps from multiple missing teeth while preserving your remaining natural teeth — a cost-effective, non-surgical solution designed with prosthodontist precision.</p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Partial Denture Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
      <h2 class="section-heading mb-6">What Are Partial Dentures?</h2>
      <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
        A removable partial denture fills the space of multiple missing teeth in an arch where some natural teeth remain. It consists of artificial teeth set in an acrylic base, often supported by a metal framework, that attaches to adjacent natural teeth via clasps or precision attachments.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-4">
        Partial dentures serve multiple purposes: restoring aesthetics and the ability to chew on both sides of the mouth, maintaining proper bite alignment by preventing opposing and adjacent teeth from shifting, and supporting natural facial contours by replacing missing tooth volume. They are removable for cleaning — typically removed at night, cleaned, and reinserted each morning.
      </p>
      <p class="text-neutral-mid leading-relaxed mb-6">
        For patients with isolated missing teeth (1–3 teeth in a row), <a href="/dental-implants" class="text-brand-blue hover:underline">dental implants</a> or <a href="/restorative-dentistry/bridges" class="text-brand-blue hover:underline">implant-supported bridges</a> are generally superior solutions because they don't require removal and don't rely on adjacent teeth for support. Partial dentures excel when multiple teeth are missing across different areas of the arch, making a fixed bridge impractical.
      </p>
      <a href="/schedule" class="btn-primary">Schedule Your Partial Denture Evaluation</a>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Partial Denture FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
