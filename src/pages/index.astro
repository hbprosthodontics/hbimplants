---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import FAQBlock from '../components/FAQBlock.astro';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  'name': 'Huntington Beach Prosthodontics',
  'url': 'https://hbimplants.com',
  'telephone': '(714) 846-1386',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '16141 Bolsa Chica St., Suite C',
    'addressLocality': 'Huntington Beach',
    'addressRegion': 'CA',
    'postalCode': '92649',
    'addressCountry': 'US',
  },
  'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'],
  'priceRange': '$$$$',
  'medicalSpecialty': 'Prosthodontics',
};

const faqs = [
  {
    question: 'What is a prosthodontist and how is it different from a general dentist?',
    answer: 'A prosthodontist is a dental specialist who completes an additional 3 years of post-doctoral training beyond dental school, focusing exclusively on the restoration and replacement of teeth. While general dentists provide a broad range of dental care, prosthodontists are specialists in complex restorations, dental implants, veneers, dentures, and full-mouth rehabilitation. When your smile involves multiple missing teeth, implants, or complex cosmetic goals, a prosthodontist delivers a higher level of expertise and precision.',
  },
  {
    question: 'What procedures does Huntington Beach Prosthodontics offer?',
    answer: 'We offer the full spectrum of prosthodontic care including dental implants, All-on-4 and All-on-X full arch implants, porcelain veneers, smile makeovers, dentures, implant-supported dentures, snap-on dentures, implant crowns and bridges, cosmetic dentistry, restorative dentistry, and clear aligners. Every treatment plan is customized to your goals, anatomy, and budget.',
  },
  {
    question: 'How do I know if I\'m a candidate for dental implants?',
    answer: 'Most adults with one or more missing teeth are candidates for dental implants. The key factors are sufficient bone volume in the jaw, healthy gums, and no uncontrolled systemic conditions. During your complimentary consultation, we perform a thorough examination including 3D imaging to evaluate your bone density and determine the optimal implant plan. Even patients with bone loss may qualify after bone grafting.',
  },
  {
    question: 'Do you offer financing for dental implants and other procedures?',
    answer: 'Yes. We understand that prosthodontic procedures represent a significant investment. We offer flexible financing options and accept most major dental insurance plans. Our team will review your coverage and help you maximize benefits. We also work with third-party financing providers so you can start treatment today and pay over time.',
  },
  {
    question: 'How long does a dental implant last?',
    answer: 'Dental implants are designed to last a lifetime. The titanium implant post integrates with your jawbone through a process called osseointegration, creating a permanent anchor. The crown on top typically lasts 15–25 years with proper care. Regular check-ups, good oral hygiene, and avoiding habits like grinding are the keys to maximizing implant longevity.',
  },
  {
    question: 'Where is Huntington Beach Prosthodontics located?',
    answer: 'We are conveniently located in Huntington Beach, California, serving patients from Huntington Beach, Fountain Valley, Costa Mesa, Newport Beach, Seal Beach, and surrounding communities. Please call us or use our online appointment form to schedule your visit.',
  },
];
---

<BaseLayout
  title="Prosthodontist Huntington Beach | Dental Implants & Smile Restoration"
  description="Huntington Beach Prosthodontics offers dental implants, All-on-X, veneers, and full smile restorations. Board-certified prosthodontist serving HB, CA. Call today."
  schema={localBusiness}
>
  <!-- Hero -->
  <section class="bg-white pt-10 pb-12 md:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 lg:gap-16 items-center">

        <!-- Left: Content -->
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center gap-1.5 border border-border-light text-mid-gray text-[10px] md:text-xs font-medium px-3 py-1 md:px-4 md:py-1.5 rounded-full mb-5 whitespace-nowrap">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-teal inline-block flex-shrink-0"></span>
            Board-Certified Prosthodontist · Huntington Beach, CA
          </div>

          <h1 class="font-serif text-4xl md:text-6xl font-bold leading-tight text-charcoal mb-5">
            Restore Your Smile.<br />
            <span class="text-brand-teal">Reclaim Your Confidence.</span>
          </h1>
          <p class="text-sm md:text-xl text-mid-gray mb-6 leading-relaxed">
            Specialist-level implants, veneers, and full smile restorations — performed by a board-certified prosthodontist, not a generalist.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/schedule" class="btn-primary text-base px-8 py-3 font-semibold text-center w-full sm:w-auto">
              Book Free Consultation
            </a>
            <a href="/dental-implants" class="btn-secondary text-base px-8 py-3 font-semibold text-center w-full sm:w-auto">
              Explore Dental Implants
            </a>
          </div>
          <div class="grid grid-cols-2 md:flex md:flex-wrap items-center gap-x-4 gap-y-3 md:gap-6 mt-6 md:mt-8 text-xs md:text-sm text-mid-gray">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              No referral needed
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              Most insurance accepted
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              Flexible financing
            </div>
          </div>
        </div>

        <!-- Right: Beach Image -->
        <div class="relative hidden lg:block">
          <div class="rounded-2xl overflow-hidden h-[520px]">
            <img
              src="/images/beach_abstract_clean_20260306_200239_01.png"
              alt="Aerial view of ocean waves at Huntington Beach"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Floating stats card -->
          <div class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-sm rounded-xl p-5 border border-border-light shadow-sm">
            <div class="grid grid-cols-3 divide-x divide-border-light text-center">
              <div class="px-3">
                <div class="text-2xl font-bold text-charcoal leading-none mb-1">5.0★</div>
                <div class="text-xs text-mid-gray">Google Rating</div>
              </div>
              <div class="px-3">
                <div class="text-2xl font-bold text-charcoal leading-none mb-1">1k+</div>
                <div class="text-xs text-mid-gray">Smiles Restored</div>
              </div>
              <div class="px-3">
                <div class="text-2xl font-bold text-charcoal leading-none mb-1">3+</div>
                <div class="text-xs text-mid-gray">Yrs Specialty Training</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-border-light py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 md:divide-x md:divide-border-light gap-y-12 md:gap-y-0">
        <div class="md:pr-10 lg:pr-16">
          <div class="text-6xl md:text-7xl font-bold text-charcoal leading-none mb-3">3+</div>
          <div class="text-sm text-mid-gray leading-snug">Years of specialty training<br />beyond dental school</div>
        </div>
        <div class="md:px-10 lg:px-16">
          <div class="text-6xl md:text-7xl font-bold text-charcoal leading-none mb-3">1k+</div>
          <div class="text-sm text-mid-gray leading-snug">Smiles restored<br />in Huntington Beach</div>
        </div>
        <div class="md:px-10 lg:px-16">
          <div class="text-6xl md:text-7xl font-bold text-charcoal leading-none mb-3">5.0</div>
          <div class="text-sm text-mid-gray leading-snug">Google rating<br />from real patients</div>
        </div>
        <div class="md:pl-10 lg:pl-16">
          <div class="text-6xl md:text-7xl font-bold text-charcoal leading-none mb-3">15+</div>
          <div class="text-sm text-mid-gray leading-snug">Year implant lifespan<br />with proper care</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">What We Offer</div>
        <h2 class="section-heading mb-4 max-w-xl">Specialized Prosthodontic Care</h2>
        <p class="text-mid-gray max-w-2xl leading-relaxed">
          From single tooth implants to complete smile transformations — performed by a specialist, not a generalist.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            href: '/dental-implants',
            title: 'Dental Implants',
            desc: 'The gold standard for tooth replacement. Permanent, natural-looking, and built to last a lifetime.',
          },
          {
            href: '/all-on-x',
            title: 'All-on-X / Full Arch',
            desc: 'Replace an entire arch of teeth with just 4–6 implants. Walk in with failing teeth, leave with a full smile.',
          },
          {
            href: '/veneers',
            title: 'Porcelain Veneers',
            desc: 'Transform the color, shape, and symmetry of your smile with ultra-thin porcelain shells crafted to perfection.',
          },
          {
            href: '/dentures',
            title: 'Dentures',
            desc: 'Modern full and partial dentures that look natural and fit comfortably — far beyond what your grandfather wore.',
          },
          {
            href: '/implant-restorations',
            title: 'Implant Restorations',
            desc: 'Crowns, bridges, and dentures anchored to implants for maximum stability, function, and natural appearance.',
          },
          {
            href: '/cosmetic-dentistry',
            title: 'Cosmetic Dentistry',
            desc: 'Teeth whitening, bonding, and comprehensive smile makeovers designed around your unique facial features and goals.',
          },
        ].map((service) => (
          <a href={service.href} class="bg-white rounded-xl p-6 border border-border-light hover:border-charcoal transition-colors duration-200 group">
            <h3 class="font-serif text-lg font-semibold text-charcoal mb-2 group-hover:text-brand-navy transition-colors">{service.title}</h3>
            <p class="text-mid-gray text-sm leading-relaxed mb-4">{service.desc}</p>
            <span class="text-sm font-medium text-charcoal group-hover:text-brand-navy transition-colors">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose a Prosthodontist -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">The Difference</div>
          <h2 class="section-heading mb-6">Why Choose a Prosthodontist?</h2>
          <p class="text-mid-gray leading-relaxed mb-6">
            Prosthodontists complete 3 additional years of residency training dedicated entirely to complex tooth restoration and replacement — beyond what any general dentist receives.
          </p>
          <p class="text-mid-gray leading-relaxed mb-6">
            At Huntington Beach Prosthodontics, Dr. Favian Cheong brings that specialized expertise to every case. Whether you need a single implant or a full-arch transformation, you're in the hands of someone who does nothing else, every day.
          </p>
          <div class="border-t border-border-light mt-8 mb-8">
            {[
              { title: 'Board-Certified Specialist', desc: '3 additional years of residency training dedicated entirely to complex tooth restoration.' },
              { title: 'Comprehensive Treatment Planning', desc: 'Latest 3D cone-beam imaging for precise diagnosis and implant placement.' },
              { title: 'All Restorations Coordinated In-House', desc: 'From surgical placement to final crown — one specialist oversees everything.' },
              { title: 'Complex Case Expertise', desc: 'Full-arch reconstruction, bone grafting, and multi-implant cases are our specialty.' },
              { title: 'Aesthetic Excellence', desc: 'Clinical precision combined with an artistic eye for symmetry and natural results.' },
            ].map((item) => (
              <div class="py-4 border-b border-border-light flex items-start gap-4">
                <div class="w-6 h-6 rounded-full border border-charcoal flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal text-sm mb-0.5">{item.title}</div>
                  <div class="text-mid-gray text-sm">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
          <a href="/about" class="btn-primary">Meet Dr. Favian Cheong</a>
        </div>

        <div class="bg-surface-2 rounded-2xl p-8 border border-border-light">
          <h3 class="font-serif text-xl font-bold text-charcoal mb-6">Prosthodontist vs. General Dentist</h3>
          <div class="space-y-4">
            {[
              { area: 'Specialty Training', pros: '3+ additional years', gen: 'No specialty training' },
              { area: 'Dental Implants', pros: 'Advanced expertise', gen: 'Basic procedures only' },
              { area: 'Complex Cases', pros: 'Primary focus', gen: 'Refer out often' },
              { area: 'Full-Mouth Rehab', pros: 'Comprehensive planning', gen: 'Limited scope' },
              { area: 'Cosmetic Precision', pros: 'Specialized training', gen: 'General aesthetics' },
            ].map((row) => (
              <div class="grid grid-cols-3 gap-2 text-sm border-b border-border-light pb-3 last:border-0">
                <div class="font-semibold text-charcoal text-xs">{row.area}</div>
                <div class="text-charcoal font-medium flex items-center gap-1.5 text-xs">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
                  </svg>
                  {row.pros}
                </div>
                <div class="text-mid-gray text-xs">{row.gen}</div>
              </div>
            ))}
          </div>
          <div class="mt-6">
            <a href="/schedule" class="btn-primary w-full block text-center">Schedule Free Consultation</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">Patient Reviews</div>
        <div class="flex items-center gap-3">
          <h2 class="section-heading">What Our Patients Say</h2>
          <div class="flex gap-0.5 mt-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
        <p class="text-mid-gray text-sm mt-2">Rated 5 stars by patients in Huntington Beach and beyond</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            quote: 'Dr. Cheong transformed my smile completely. I can\'t thank him enough for the exceptional care I received! Highly recommend!',
            name: 'Lindsey U.',
            location: 'Huntington Beach',
          },
          {
            quote: 'Dr. Cheong\'s office and team are incredible... I drive from Newport Beach to see them. Excellent experience.',
            name: 'Spencer L.',
            location: 'Newport Beach',
          },
          {
            quote: 'By far the best dental experience I\'ve ever had. Amazing service and quality care. Dr. Cheong is simply the best dentist in So-Cal. Efficient, honest, skilled and super chill.',
            name: 'Michelle L.',
            location: 'Southern California',
          },
        ].map((t) => (
          <div class="bg-white rounded-xl p-6 border border-border-light flex flex-col">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-mid-gray leading-relaxed text-sm flex-1 mb-4 italic">"{t.quote}"</p>
            <div>
              <div class="font-semibold text-charcoal text-sm">{t.name}</div>
              <div class="text-xs text-mid-gray">{t.location}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Common Questions About Prosthodontic Care" />
    </div>
  </section>

  <!-- CTA with beach image background -->
  <section class="py-8 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-2xl overflow-hidden">
        <img
          src="/images/beach_abstract_20260306_195512_03.png"
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          aria-hidden="true"
        />
        <div class="relative py-12 md:py-16 px-8 md:px-16 text-center">
          <h2 class="font-serif text-2xl md:text-3xl font-bold mb-4 text-charcoal">Ready to Restore Your Smile?</h2>
          <p class="max-w-2xl mx-auto mb-8 leading-relaxed text-charcoal/70">
            Schedule a consultation with Dr. Favian Cheong, your board-certified prosthodontist in Huntington Beach. We'll create a personalized treatment plan just for you.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="/schedule" class="btn-primary text-base px-8 py-4 font-semibold">
              Schedule Your Consultation
            </a>
            <a href="tel:7148461386" class="font-medium text-base text-charcoal/70 hover:text-charcoal transition-colors">
              Or Call: (714) 846-1386
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
