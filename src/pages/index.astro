---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQBlock from '../components/FAQBlock.astro';
import CTABlock from '../components/CTABlock.astro';
import { localBusinessSchema, site, address, doctor } from '../config/site';

const bookHref = site.bookingUrl;
import { serviceCategories } from '../config/services';

// Fetch real Google reviews at build time
const PLACES_API_KEY = import.meta.env.GOOGLE_PLACES_API_KEY;
const PLACE_ID = import.meta.env.GOOGLE_PLACE_ID;

const fallbackTestimonials = [
  { quote: 'Dr. Cheong transformed my smile completely. I can\'t thank him enough for the exceptional care I received! Highly recommend!', name: 'Lindsey U.', meta: 'Huntington Beach' },
  { quote: 'Dr. Cheong\'s office and team are incredible... I drive from Newport Beach to see them. Excellent experience.', name: 'Spencer L.', meta: 'Newport Beach' },
  { quote: 'By far the best dental experience I\'ve ever had. Amazing service and quality care. Dr. Cheong is simply the best dentist in So-Cal. Efficient, honest, skilled and super chill.', name: 'Michelle L.', meta: 'Southern California' },
];

let testimonials = fallbackTestimonials;
let googleRating = 4.9;
let googleReviewCount = 73;

try {
  if (PLACES_API_KEY && PLACE_ID) {
    const res = await fetch(
      `https://maps.googleapis.com/maps/api/place/details/json?place_id=${PLACE_ID}&fields=rating,user_ratings_total,reviews&reviews_sort=newest&key=${PLACES_API_KEY}`
    );
    const data = await res.json();
    if (data.result) {
      googleRating = data.result.rating ?? googleRating;
      googleReviewCount = data.result.user_ratings_total ?? googleReviewCount;
      const fetched = (data.result.reviews ?? [])
        .filter((r: any) => r.rating >= 4 && r.text?.length > 40)
        .slice(0, 3)
        .map((r: any) => ({ quote: r.text, name: r.author_name, meta: r.relative_time_description }));
      if (fetched.length >= 2) testimonials = fetched;
    }
  }
} catch (_) {
  // silently fall back
}

const localBusiness = {
  ...localBusinessSchema,
  'aggregateRating': {
    '@type': 'AggregateRating',
    'ratingValue': googleRating,
    'reviewCount': googleReviewCount,
    'bestRating': 5,
    'worstRating': 1,
  },
};

const faqs = [
  {
    question: 'What is a prosthodontist and how is it different from a general dentist?',
    answer: 'A prosthodontist is a dental specialist who completes an additional 3 years of post-doctoral training beyond dental school, focusing exclusively on the restoration and replacement of teeth. While general dentists provide a broad range of dental care, prosthodontists are specialists in complex restorations, dental implants, veneers, dentures, and full-mouth rehabilitation. When your smile involves multiple missing teeth, implants, or complex cosmetic goals, a prosthodontist delivers a higher level of expertise and precision.',
  },
  {
    question: 'What procedures does Huntington Beach Prosthodontics offer?',
    answer: 'We offer the full spectrum of prosthodontic care including dental implants, All-on-4 and All-on-X full arch implants, porcelain veneers, smile makeovers, dentures, implant-supported dentures, snap-on dentures, implant crowns and bridges, cosmetic dentistry, restorative dentistry, and clear aligners. Every treatment plan is customized to your goals, anatomy, and budget.',
  },
  {
    question: "How do I know if I'm a candidate for dental implants?",
    answer: 'Most adults with one or more missing teeth are candidates for dental implants. The key factors are sufficient bone volume in the jaw, healthy gums, and no uncontrolled systemic conditions. During your consultation, we perform a thorough examination including 3D imaging to evaluate your bone density and determine the optimal implant plan. Even patients with bone loss may qualify after bone grafting.',
  },
  {
    question: 'Do you offer financing for dental implants and other procedures?',
    answer: 'Yes. We understand that prosthodontic procedures represent a significant investment. We offer flexible financing options and accept most major dental insurance plans. Our team will review your coverage and help you maximize benefits. We also work with third-party financing providers so you can start treatment today and pay over time.',
  },
  {
    question: 'How long does a dental implant last?',
    answer: 'Dental implants are designed to last a lifetime. The titanium implant post integrates with your jawbone through a process called osseointegration, creating a permanent anchor. The crown on top typically lasts 15–25 years with proper care. Regular check-ups, good oral hygiene, and avoiding habits like grinding are the keys to maximizing implant longevity.',
  },
  {
    question: 'Do you accept dental insurance?',
    answer: 'Yes. We accept most major dental insurance plans and will help you maximize your benefits. Our team provides a clear breakdown of estimated costs before you begin any treatment. For procedures not fully covered by insurance, we offer flexible third-party financing options so you can start treatment and pay over time.',
  },
  {
    question: 'How do I get started with treatment?',
    answer: 'The easiest first step is to schedule a consultation. During this visit we take complete digital records, review your dental history, and discuss your goals. You\'ll leave with a clear understanding of your options and a customized treatment plan, with no obligation to proceed.',
  },
  {
    question: 'How soon can I get an appointment?',
    answer: 'We typically see new patients within a few days to a week. Call us directly at (714) 846-1386 for the fastest scheduling, or use our online appointment request form and we\'ll follow up within one business day.',
  },
  {
    question: 'Where is Huntington Beach Prosthodontics located?',
    answer: 'We are conveniently located at 16141 Bolsa Chica St., Suite C in Huntington Beach, California, serving patients from Huntington Beach, Fountain Valley, Costa Mesa, Newport Beach, Seal Beach, and surrounding communities. Please call us or use our online appointment form to schedule your visit.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.map(f => ({
    '@type': 'Question',
    'name': f.question,
    'acceptedAnswer': { '@type': 'Answer', 'text': f.answer },
  })),
};
---

<BaseLayout
  title="Dentist in Huntington Beach | General Care, Implants & Veneers"
  description="Huntington Beach Prosthodontics offers everything from routine cleanings to dental implants, All-on-X, veneers, and full smile restorations. General and specialty dental care under one roof in HB, CA."
  schema={[localBusiness, faqSchema]}
>
  <!-- Hero -->
  <section class="bg-white pt-10 pb-12 md:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 lg:gap-16 items-center">

        <!-- Left: Content -->
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center gap-1.5 border border-border-light text-mid-gray text-[10px] md:text-xs font-medium px-3 py-1 md:px-4 md:py-1.5 rounded-full mb-5 whitespace-nowrap">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-teal inline-block flex-shrink-0"></span>
            General & Specialty Dental Care · Huntington Beach, CA
          </div>

          <h1 class="font-serif text-4xl md:text-6xl font-bold leading-tight text-charcoal mb-5">
            Restore Your Smile.<br />
            <span class="text-brand-teal">Reclaim Your Confidence.</span>
          </h1>
          <p class="text-sm md:text-xl text-charcoal mb-6 leading-relaxed">
            From routine cleanings to implants, veneers, and complete smile restorations — general and specialty dental care, all under one roof.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href={bookHref} target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-3 font-semibold text-center w-full sm:w-auto">
              Book Consultation
            </a>
            <a href="/dental-implants" class="btn-secondary text-base px-8 py-3 font-semibold text-center w-full sm:w-auto">
              Explore Dental Implants
            </a>
          </div>
          <div class="grid grid-cols-2 md:flex md:flex-wrap items-center gap-x-4 gap-y-3 md:gap-6 mt-6 md:mt-8 text-xs md:text-sm text-charcoal">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              No referral needed
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              Most insurance accepted
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-charcoal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
              </svg>
              Flexible financing
            </div>
          </div>
        </div>

        <!-- Right: Beach Image -->
        <div class="relative hidden lg:block">
          <div class="rounded-2xl overflow-hidden h-[520px]">
            <img
              src="/images/heroes/hero-abstract-clean.webp"
              alt="Aerial view of ocean waves at Huntington Beach"
              class="w-full h-full object-cover"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Who We Are: Doctors intro -->
  <section class="bg-brand-navy py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-white/50 mb-3">Who We Are</div>
          <h2 class="font-serif text-4xl md:text-5xl font-bold leading-tight text-white mb-6">Two UCLA-Trained Doctors</h2>
          <p class="text-white/70 leading-relaxed mb-4">
            {doctor.name} is a certified prosthodontist — one of nine ADA-recognized dental specialists — who completed his residency at UCSF. Dr. Janelle Cheong provides comprehensive general dental care. Together, they offer advanced and preventive care under one roof.
          </p>
          <p class="text-white/70 leading-relaxed mb-6">
            We build treatment plans around your anatomy, goals, and life circumstances — not a one-size-fits-all approach. Your first visit includes a thorough exam, complete digital records, and an honest discussion of options, timelines, and costs before any commitment.
          </p>
          <p class="text-white font-semibold mb-8">Our mission is to restore your smile with precision and expertise.</p>
          <a href="/about" class="inline-block bg-white text-brand-navy font-semibold px-6 py-3 rounded-full hover:bg-white/90 transition-colors text-center">Meet Our Doctors</a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <a href="/about#dr-favian" class="group">
            <img src="/images/team/dr-favian-cheong.webp" alt="Dr. Favian Cheong" class="rounded-xl w-full aspect-[3/4] object-cover object-top mb-2 group-hover:opacity-95 transition-opacity" />
            <div class="font-semibold text-white text-sm">Dr. Favian Cheong</div>
            <div class="text-brand-teal text-xs font-medium">Prosthodontist</div>
          </a>
          <a href="/about#dr-janelle" class="group">
            <img src="/images/team/dr-janelle-cheong.webp" alt="Dr. Janelle Cheong" class="rounded-xl w-full aspect-[3/4] object-cover object-top mb-2 group-hover:opacity-95 transition-opacity" />
            <div class="font-semibold text-white text-sm">Dr. Janelle Cheong</div>
            <div class="text-brand-teal text-xs font-medium">General Dentist</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">What We Offer</div>
        <h2 class="section-heading mb-4 max-w-xl">Complete Dental Care, Under One Roof</h2>
        <p class="text-charcoal max-w-2xl leading-relaxed">
          Routine checkups and cleanings to dental implants and full smile makeovers — a general dentist and certified prosthodontist working together for your complete dental health.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {serviceCategories.map((cat) => (
          <a href={cat.href} class="bg-brand-navy rounded-xl p-6 hover:opacity-90 transition-opacity group block">
            <h3 class="font-serif text-lg font-semibold text-white mb-2">{cat.heading}</h3>
            <p class="text-white/60 text-sm leading-relaxed mb-4">{cat.desc}</p>
            <span class="text-sm font-medium text-brand-teal">Learn more →</span>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/services" class="btn-secondary">See All Services</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">Patient Reviews</div>
        <div class="flex items-center gap-3">
          <h2 class="section-heading">What Our Patients Say</h2>
          <div class="flex gap-0.5 mt-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
        <p class="text-mid-gray text-sm mt-2">Rated {googleRating} stars · {googleReviewCount} Google reviews from patients in Huntington Beach and beyond</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="bg-white rounded-xl p-6 border border-border-light flex flex-col">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-brand-teal" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-charcoal leading-relaxed text-sm flex-1 mb-4 italic">"{t.quote}"</p>
            <div>
              <div class="font-semibold text-charcoal text-sm">{t.name}</div>
              <div class="text-xs text-mid-gray">{t.meta}</div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 items-center justify-center">
        <a href="https://g.page/r/CU4itT3RNhmQEBM/review" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Leave Us a Google Review
        </a>
        <a href="https://share.google/HnGTXT5RBHoUzW0kE" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-charcoal hover:text-brand-teal transition-colors">
          Read all {googleReviewCount} reviews on Google →
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Teaser -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">Real Patient Results</div>
        <h2 class="section-heading">See What's Possible</h2>
        <p class="text-charcoal mt-3 max-w-xl mx-auto">Every smile is unique. Browse our patient gallery to see the results we deliver.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        {[
          { src: '/images/gallery/edc2a9_63f959b1683a47f9b5fb4916473d5811~mv2.avif', alt: 'Before and after dental implant restoration at Huntington Beach Prosthodontics' },
          { src: '/images/gallery/edc2a9_bf872454f2f4482a8b3ebd4a4e1cf8b1~mv2.avif', alt: 'Porcelain veneer smile makeover showing natural tooth color and symmetry' },
          { src: '/images/gallery/edc2a9_f4b39cbd01d24b449cba3be2c75552f4~mv2.avif', alt: 'Full mouth reconstruction result with implant-supported crowns and bridges' },
        ].map((img) => (
          <a href="/gallery" class="block overflow-hidden rounded-xl aspect-[4/3] bg-surface-2">
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
          </a>
        ))}
      </div>
      <div class="text-center">
        <a href="/gallery" class="btn-primary">View Full Gallery &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Why Choose a Prosthodontist -->
  <section class="bg-brand-navy py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-12">
        <!-- Left: Text -->
        <div>
          <div class="text-xs font-semibold uppercase tracking-widest text-white/50 mb-3">The Difference</div>
          <h2 class="font-serif text-4xl md:text-5xl font-bold leading-tight text-white mb-6">Why Choose a Prosthodontist?</h2>
          <p class="text-white/70 leading-relaxed mb-6">
            <strong class="text-white">A prosthodontist is a dental specialist</strong> who focuses exclusively on restoring and replacing teeth — implants, veneers, dentures, and full-mouth rehabilitation. Prosthodontists complete 3 additional years of residency training dedicated entirely to this work — beyond what any general dentist receives. <a href="/blog/what-is-a-prosthodontist" class="text-brand-teal font-medium hover:text-white transition-colors">Learn more →</a>
          </p>
          <p class="text-white/70 leading-relaxed">
            At Huntington Beach Prosthodontics, Dr. Favian Cheong brings that expertise to every case. Whether you need a single implant or a full-arch transformation, you're in the hands of someone who does nothing else, every day.
          </p>
        </div>

        <!-- Right: Comparison Table -->
        <div class="bg-white/10 rounded-2xl p-8 border border-white/20 self-start">
        <h3 class="font-serif text-xl font-bold text-white mb-6">Prosthodontist vs. General Dentist</h3>
          <div class="space-y-4">
            {[
              { area: 'Advanced Training', pros: '3+ additional years', gen: 'No specialty training' },
              { area: 'Dental Implants', pros: 'Advanced expertise', gen: 'Basic procedures only' },
              { area: 'Complex Cases', pros: 'Primary focus', gen: 'Refer out often' },
              { area: 'Full-Mouth Rehab', pros: 'Comprehensive planning', gen: 'Limited scope' },
              { area: 'Cosmetic Precision', pros: 'Specialized training', gen: 'General aesthetics' },
            ].map((row) => (
              <div class="grid grid-cols-3 gap-2 text-sm border-b border-white/10 pb-3 last:border-0">
                <div class="font-semibold text-white/70 text-xs">{row.area}</div>
                <div class="text-white font-medium flex items-center gap-1.5 text-xs">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M8.5 12.5l2.5 2.5 4.5-5"/>
                  </svg>
                  {row.pros}
                </div>
                <div class="text-white/40 text-xs">{row.gen}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="border-t border-white/10 pt-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
          {[
            { title: 'Prosthodontic Residency Training', desc: '3 additional years of residency training dedicated entirely to complex tooth restoration.' },
            { title: 'Comprehensive Treatment Planning', desc: 'Latest 3D cone-beam imaging for precise diagnosis and implant placement.' },
            { title: 'All Restorations Coordinated In-House', desc: 'From surgical placement to final crown — one doctor oversees everything.' },
            { title: 'Complex Case Expertise', desc: 'Full-arch reconstruction, bone grafting, and multi-implant cases are our focus.' },
            { title: 'Aesthetic Excellence', desc: 'Clinical precision combined with an artistic eye for symmetry and natural results.' },
          ].map((item) => (
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full border border-white/40 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <div class="font-semibold text-white text-sm mb-0.5">{item.title}</div>
                <div class="text-white/60 text-sm">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/about" class="inline-block bg-white text-brand-navy font-semibold px-6 py-3 rounded-full hover:bg-white/90 transition-colors text-center">Meet Dr. Favian Cheong</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faqs" class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Common Questions About Prosthodontic Care" />
    </div>
  </section>

  <!-- Map -->
  <section class="py-16 md:py-20 bg-surface-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <div class="text-xs font-semibold uppercase tracking-widest text-mid-gray mb-3">Visit Us</div>
        <h2 class="section-heading mb-2">Find Our Office</h2>
        <p class="text-charcoal max-w-xl">
          {address.full} — serving Huntington Beach, Costa Mesa, Newport Beach, and surrounding communities.
        </p>
      </div>
      <div class="rounded-2xl overflow-hidden border border-border-light h-64 md:h-96">
        <iframe
          src="https://maps.google.com/maps?q=16141+Bolsa+Chica+St+Suite+C,+Huntington+Beach,+CA+92649&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Huntington Beach Prosthodontics location map"
        ></iframe>
      </div>
      <div class="mt-6 flex flex-col sm:flex-row gap-4 items-center justify-between">
        <a href="https://maps.google.com/?q=16141+Bolsa+Chica+St+Suite+C+Huntington+Beach+CA+92649" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-brand-teal hover:text-charcoal transition-colors">
          Get directions →
        </a>
        <a href={bookHref} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm px-6 py-2.5">
          Book Appointment
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock />
    </div>
  </section>
</BaseLayout>
