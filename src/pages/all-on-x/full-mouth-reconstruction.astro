---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const procedureSchema = { '@context': 'https://schema.org', '@type': 'MedicalProcedure', 'name': 'Full Mouth Reconstruction', 'description': 'Full mouth reconstruction rebuilds all teeth in both the upper and lower jaws using a coordinated combination of implants, crowns, bridges, and other prosthodontic procedures.', 'procedureType': 'https://schema.org/TherapeuticProcedure', 'bodyLocation': 'Mouth', 'followup': 'As recommended by your prosthodontist' };
const faqs = [
  { question: 'What is full mouth reconstruction?', answer: 'Full mouth reconstruction (also called full mouth rehabilitation) is a comprehensive dental treatment plan that rebuilds all or most of the teeth in both jaws. Unlike a smile makeover that focuses on aesthetics, full mouth reconstruction addresses functional issues — bite alignment, worn teeth, bone loss, and tooth loss — alongside aesthetics. It typically combines multiple procedures: implants, crowns, bridges, veneers, bone grafting, and sometimes orthodontics.' },
  { question: 'Who needs full mouth reconstruction?', answer: 'Full mouth reconstruction is appropriate for patients with extensive tooth wear from acid erosion or bruxism (teeth grinding), multiple missing teeth requiring replacement, significant decay affecting most or all teeth, dental trauma affecting the bite, or congenital conditions (missing multiple teeth from birth). Patients with failing teeth who need a comprehensive new start are also excellent candidates.' },
  { question: 'How long does full mouth reconstruction take?', answer: 'Full mouth reconstruction is typically one of the longer dental treatment experiences, often spanning 12–24 months depending on the procedures involved. Simple cases with crowns and veneers may be completed in 3–6 months. Cases requiring bone grafting, implants, and healing time can take 18–24 months from the first procedure to the final restoration. Dr. Favian Cheong provides a detailed timeline at your planning consultation.' },
  { question: 'Is full mouth reconstruction done all at once?', answer: 'Rarely. Most full mouth reconstruction cases are sequenced across multiple appointments and phases. Typically: Phase 1 addresses urgent needs (extractions, infection control), Phase 2 involves bone grafting and implant placement (if needed), Phase 3 completes individual restorations. This sequenced approach is both clinically sound and financially manageable — it allows you to pay for treatment in stages.' },
  { question: 'How much does full mouth reconstruction cost?', answer: 'Full mouth reconstruction is the most significant dental investment available. Depending on the procedures involved, costs typically range from $30,000–$80,000+ for comprehensive cases. Implant-based full mouth reconstruction for both arches can reach $60,000–$90,000. However, this is a one-time investment in a set of teeth designed to last 20+ years. We provide a complete phased treatment plan with fee estimates at your consultation.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="Full Mouth Reconstruction Huntington Beach | Total Smile Rehabilitation"
  description="Full mouth reconstruction in Huntington Beach restores every tooth using implants, crowns, and advanced prosthodontic techniques. Board-certified specialist care."
  schema={[localBusiness, procedureSchema, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-gold text-sm font-semibold uppercase tracking-wide mb-3">All-on-X › Full Mouth Reconstruction</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Full Mouth Reconstruction in Huntington Beach —<br />
          <span class="text-brand-gold">Complete Dental Restoration by a Specialist</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          Full mouth reconstruction rebuilds every tooth in both jaws — addressing function, aesthetics, and long-term health through a coordinated, sequenced treatment plan designed by Dr. Favian Cheong, board-certified prosthodontist.
        </p>
        <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold">Schedule Your Reconstruction Consultation</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-heading mb-6">When Everything Needs to Be Rebuilt</h2>
        <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
          Some patients reach a point where individual repairs are no longer sufficient — where the cumulative damage from years of decay, erosion, grinding, or neglect requires a comprehensive approach. Full mouth reconstruction is the specialty of prosthodontists. It is the procedure that brings together every discipline in restorative dentistry — implantology, crown and bridge, occlusal therapy, and aesthetics — into a single, coordinated plan.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          Dr. Favian Cheong approaches every reconstruction case with meticulous attention to the fundamentals: bite alignment (occlusion) must be established correctly before any final restorations are placed; vertical dimension of occlusion (the space between upper and lower jaws when teeth are together) must be evaluated and often restored; and the patient's facial aesthetics must guide the design of every crown and restoration.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-6">
          The most common full mouth reconstruction patients at our Huntington Beach practice are: patients with severe acid erosion from GERD or dietary habits, patients with extreme bruxism who have ground their teeth to the gum line, patients who have lost most or all teeth and need combined implant and denture planning, and patients who received poor dental work elsewhere that needs to be redone comprehensively. See our <a href="/dental-implants" class="text-brand-blue hover:underline">dental implants</a> and <a href="/all-on-x" class="text-brand-blue hover:underline">All-on-X</a> pages for information on implant-based reconstruction options.
        </p>

        <h2 class="section-subheading mb-4">Prosthodontist Advantage in Full Mouth Cases</h2>
        <p class="text-neutral-mid leading-relaxed mb-6">
          Full mouth reconstruction is the procedure where the prosthodontist's unique training is most critical. The complexity of coordinating multiple procedures, managing changes to bite dimension, and ensuring that every restoration works together as a functional, aesthetic system requires the specific expertise that prosthodontic residency training provides. Attempting full mouth reconstruction with a generalist risks bite problems, premature restoration failure, and aesthetic outcomes that don't hold up over time.
        </p>
        <a href="/schedule" class="btn-primary">Start Your Reconstruction Journey</a>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="Full Mouth Reconstruction FAQ" />
    </div>
  </section>
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
