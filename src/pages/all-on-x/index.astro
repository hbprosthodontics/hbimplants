---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABlock from '../../components/CTABlock.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const localBusiness = { '@context': 'https://schema.org', '@type': 'Dentist', 'name': 'Huntington Beach Prosthodontics', 'url': 'https://hbimplants.com', 'telephone': '(714) 846-1386', 'address': { '@type': 'PostalAddress', 'streetAddress': '16141 Bolsa Chica St., Suite C', 'addressLocality': 'Huntington Beach', 'addressRegion': 'CA', 'postalCode': '92649', 'addressCountry': 'US' }, 'openingHours': ['Mo 09:00-17:00', 'We 09:00-17:00', 'Fr 09:00-17:00', 'Sa 10:00-14:00'], 'priceRange': '$$$$', 'medicalSpecialty': 'Prosthodontics' };
const procedureSchema = { '@context': 'https://schema.org', '@type': 'MedicalProcedure', 'name': 'All-on-4 / All-on-X Full Arch Dental Implants', 'description': 'All-on-4 and All-on-X implant procedures replace an entire arch of teeth using 4–6 strategically placed dental implants supporting a fixed, permanent prosthesis.', 'procedureType': 'https://schema.org/TherapeuticProcedure', 'bodyLocation': 'Mouth', 'followup': 'As recommended by your prosthodontist' };
const faqs = [
  { question: 'What is All-on-4 and how is it different from regular implants?', answer: 'All-on-4 (also called All-on-X) is a full-arch implant procedure where 4–6 implants support an entire arch of teeth — upper, lower, or both. Unlike individual implants that replace one tooth each, All-on-4 uses 4 strategically placed implants as anchors for a fixed prosthesis holding all your teeth. The posterior implants are angled (typically 30–45 degrees) to take advantage of denser bone and avoid sinus cavities, often eliminating the need for bone grafting.' },
  { question: 'Am I a candidate for All-on-4 in Huntington Beach?', answer: 'All-on-4 is designed for patients who are missing most or all of their teeth in one or both arches, or those with failing teeth that cannot be saved. Most patients who qualify include denture wearers who want a fixed alternative, people with multiple failing teeth, and patients with significant but not extreme bone loss (one advantage of All-on-4 is that it can often proceed without bone grafting). A 3D CBCT scan determines definitively whether you qualify.' },
  { question: 'Do I get teeth the same day as All-on-4 surgery?', answer: 'Yes. In most All-on-4 cases, a full-arch temporary prosthesis is attached the same day as implant surgery — often within hours. This "teeth in a day" approach means you walk in with failing or no teeth and leave with a full smile that same day. The temporary prosthesis is worn during the healing period (3–6 months), then replaced with your final, permanent prosthesis.' },
  { question: 'How much does All-on-4 cost in Huntington Beach?', answer: 'All-on-4 for a single arch typically ranges from $20,000–$35,000 in the Huntington Beach area, depending on the number of implants, type of final prosthesis (acrylic, zirconia, etc.), and any preparatory procedures. Full-mouth (both arches) ranges from $40,000–$65,000. We provide an itemized estimate after your 3D scan and consultation. Financing is available, and some insurance plans contribute.' },
  { question: 'How long do All-on-4 implants last?', answer: 'The implant posts used in All-on-4 are designed to last a lifetime with proper care. The prosthesis (the set of teeth attached to the implants) has a lifespan of 10–20 years depending on material (acrylic vs. zirconia) and oral hygiene habits. Zirconia hybrid prostheses are significantly more durable and stain-resistant than acrylic options. Regular check-ups are essential for long-term success.' },
  { question: 'What is the difference between All-on-4 and dentures?', answer: 'Traditional dentures rest on your gum tissue and rely on suction, adhesives, or natural retention — they move when you eat and can cause bone loss over time. All-on-4 implants are anchored to your jawbone. The prosthesis is fixed and does not move — you eat, speak, and laugh exactly as you would with natural teeth. All-on-4 also preserves bone (dentures accelerate bone resorption) and does not require adhesives or nightly removal.' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', 'mainEntity': faqs.map(f => ({ '@type': 'Question', 'name': f.question, 'acceptedAnswer': { '@type': 'Answer', 'text': f.answer } })) };
---
<BaseLayout
  title="All-on-4 Huntington Beach | Full-Arch Dental Implants"
  description="All-on-4 dental implants in Huntington Beach, CA. Replace an entire arch of teeth with just 4 implants in one day. Board-certified prosthodontist. Call (714) 846-1386."
  schema={[localBusiness, procedureSchema, faqSchema]}
>
  <section class="bg-surface-2 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-teal text-sm font-semibold uppercase tracking-wide mb-3">All-on-X Full Arch Implants — Huntington Beach</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          All-on-4 Huntington Beach —<br />
          <span class="text-brand-teal">A Full Arch of Teeth, Supported by 4 Implants</span>
        </h1>
        <p class="text-mid-gray text-lg leading-relaxed mb-8">
          All-on-4 (All-on-X) replaces a full arch of missing or failing teeth with a fixed, permanent prosthesis anchored by just 4–6 dental implants. Walk in the morning with no teeth. Walk out the same day with a complete smile.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/schedule" class="btn-gold text-base px-8 py-4 font-semibold text-center">Schedule Free Consultation</a>
          <a href="/all-on-x/all-on-4" class="btn-secondary text-base px-8 py-4 font-semibold text-center">All-on-4 Details</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="section-heading mb-6">What Is All-on-4 / All-on-X?</h2>
        <p class="text-neutral-mid leading-relaxed mb-4 text-lg">
          All-on-4 is a full-arch implant solution developed to give patients with extensive tooth loss a fixed, non-removable set of teeth anchored by a minimum of 4 dental implants per arch. The "X" in All-on-X refers to the number of implants used — 4, 5, or 6 — based on your bone density, anatomy, and the type of prosthesis planned.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          The procedure is transformative. Patients who have struggled with uncomfortable dentures, who are missing most of their teeth, or who have failing teeth requiring extraction are ideal candidates. All-on-4 delivers a complete set of fixed teeth — you eat, speak, and smile with full confidence. Unlike dentures, they do not slip, require no adhesives, and do not come out at night.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-6">
          At Huntington Beach Prosthodontics, Dr. Favian Cheong provides comprehensive All-on-4 care — from the initial 3D planning through the final prosthesis delivery. The ability to handle both the surgical coordination and the restorative design in one specialist practice is a significant advantage for outcome quality. Learn more about our specific <a href="/all-on-x/all-on-4" class="text-brand-blue hover:underline">All-on-4 implant procedure</a> or explore <a href="/all-on-x/full-arch" class="text-brand-blue hover:underline">full arch implant options</a>.
        </p>

        <h2 class="section-subheading mt-10 mb-6">All-on-X vs. Traditional Dentures vs. Individual Implants</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-surface-2">
                <th class="px-4 py-3 text-left font-semibold">Feature</th>
                <th class="px-4 py-3 text-center font-semibold">All-on-4</th>
                <th class="px-4 py-3 text-center font-semibold">Dentures</th>
                <th class="px-4 py-3 text-center font-semibold">Individual Implants</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-border">
              {[
                ['Fixed (non-removable)', '✓ Yes', '✗ No', '✓ Yes'],
                ['Bone preservation', '✓ Yes', '✗ No', '✓ Yes'],
                ['Same-day teeth', '✓ Often', '✓ Yes', '✗ No'],
                ['Bone graft usually needed', '✗ Often not', '✗ No', '⚠ Sometimes'],
                ['Full arch solution', '✓ Yes', '✓ Yes', '✗ Per tooth'],
                ['Prosthesis longevity', '10–20 yrs', '5–10 yrs', '15–25 yrs (crown)'],
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-brand-light'}>
                  {row.map((cell, j) => (
                    <td class={`px-4 py-3 ${j === 0 ? 'font-medium text-brand-navy' : 'text-center text-neutral-mid'}`}>{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2 class="section-subheading mt-10 mb-6">Why Choose a Prosthodontist for All-on-4 in Huntington Beach?</h2>
        <p class="text-neutral-mid leading-relaxed mb-4">
          All-on-4 is among the most technically demanding procedures in dentistry. It requires precise implant angulation, sophisticated occlusal planning, and expert prosthetic design. Mistakes in any of these areas lead to implant failure, prosthesis fracture, or bite problems — outcomes that are costly and painful to correct.
        </p>
        <p class="text-neutral-mid leading-relaxed mb-4">
          Prosthodontists receive the deepest training in full-arch rehabilitation. Dr. Favian Cheong applies specialist-level knowledge to every All-on-4 case: 3D surgical planning, implant angulation optimization, immediate-load protocols, and high-quality prosthetic fabrication. The result is a fixed arch that functions comfortably for decades.
        </p>
        <p class="text-neutral-mid leading-relaxed">
          If you are considering All-on-4, also explore our <a href="/all-on-x/all-on-6" class="text-brand-blue hover:underline">All-on-6 option</a> for maximum stability, <a href="/all-on-x/full-mouth-reconstruction" class="text-brand-blue hover:underline">full mouth reconstruction</a> for complex cases, or our <a href="/dentures" class="text-brand-blue hover:underline">denture alternatives</a> comparison. For patients who want a removable implant solution, our <a href="/implant-restorations/snap-on" class="text-brand-blue hover:underline">snap-on denture</a> option may also be suitable.
        </p>
      </div>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQBlock faqs={faqs} heading="All-on-4 FAQ — Huntington Beach" />
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><CTABlock /></div>
  </section>
</BaseLayout>
