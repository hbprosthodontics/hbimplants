---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import { localBusinessSchema as localBusiness } from '../config/site';
import { serviceCategories } from '../config/services';
---
<BaseLayout
  title="Dental Services Huntington Beach | Prosthodontist HB, CA"
  description="Complete list of dental services at Huntington Beach Prosthodontics — implants, veneers, crowns, dentures, and more. Certified prosthodontic specialist. Call (714) 846-1386."
  schema={[localBusiness]}
>
  <section class="bg-surface-2 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-brand-teal text-sm font-semibold uppercase tracking-wide mb-3">Huntington Beach Prosthodontics</div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6 leading-tight">
          All Dental Services —<br />
          <span class="text-brand-teal">Specialist Care Under One Roof</span>
        </h1>
        <p class="text-charcoal text-lg leading-relaxed">
          From single implants to full-mouth reconstruction, porcelain veneers to routine cleanings — every service delivered by or under the supervision of a certified prosthodontic specialist.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      {serviceCategories.map(cat => (
        <div>
          <div class="flex items-baseline gap-4 mb-8">
            <h2 class="section-heading">{cat.heading}</h2>
            <a href={cat.href} class="text-brand-blue text-sm hover:underline">Overview →</a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {cat.services.map((svc) => (
              <a href={svc.href} class="card group hover:border-brand-teal hover:shadow-md transition-all duration-200 block">
                <div class="font-semibold text-brand-navy mb-2 group-hover:text-brand-teal transition-colors">{svc.name}</div>
                <p class="text-charcoal text-sm leading-relaxed mb-3">{svc.desc}</p>
                <span class="text-brand-blue text-sm font-medium">Learn more →</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CTABlock heading="Not sure where to start?" subheading="Book a consultation — Dr. Favian Cheong will evaluate your needs and recommend the right treatment plan for you." />
    </div>
  </section>
</BaseLayout>
