---
interface Props {
  heading?: string;
  subheading?: string;
  primaryCTA?: string;
  primaryHref?: string;
  phone?: string;
  variant?: 'dark' | 'light' | 'white';
}

const {
  heading = 'Ready to Restore Your Smile?',
  subheading = 'Schedule a consultation with Dr. Favian Cheong, your certified prosthodontic specialist in Huntington Beach. We\'ll create a personalized treatment plan just for you.',
  primaryCTA = 'Book Free Consultation',
  primaryHref = '/schedule',
  phone = '(714) 846-1386',
  variant = 'light',
} = Astro.props;

const bgClass = {
  dark: 'bg-charcoal text-white',
  light: 'bg-surface-2 text-charcoal',
  white: 'bg-white text-charcoal border border-border-light',
}[variant];

const headingClass = {
  dark: 'text-white',
  light: 'text-charcoal',
  white: 'text-charcoal',
}[variant];

const subClass = {
  dark: 'text-neutral-400',
  light: 'text-mid-gray',
  white: 'text-mid-gray',
}[variant];

const phoneClass = {
  dark: 'text-neutral-400 hover:text-white',
  light: 'text-mid-gray hover:text-charcoal',
  white: 'text-mid-gray hover:text-charcoal',
}[variant];
---

<section class={`${bgClass} rounded-2xl p-8 md:p-12 text-center`}>
  <h2 class={`font-serif text-2xl md:text-3xl font-bold mb-4 ${headingClass}`}>
    {heading}
  </h2>
  <p class={`max-w-2xl mx-auto mb-8 leading-relaxed ${subClass}`}>
    {subheading}
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <a href={primaryHref} class={`${variant === 'dark' ? 'btn-secondary border-white text-white hover:bg-white hover:text-charcoal' : 'btn-primary'} text-base px-8 py-4 font-semibold`}>
      {primaryCTA}
    </a>
    <a
      href={`tel:${phone.replace(/\D/g, '')}`}
      class={`font-medium text-base transition-colors ${phoneClass}`}
    >
      Or Call: {phone}
    </a>
  </div>
</section>
