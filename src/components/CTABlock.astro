---
import { site } from '../config/site';

interface Props {
  heading?: string;
  subheading?: string;
  primaryCTA?: string;
  primaryHref?: string;
  primaryExternal?: boolean;
  phone?: string;
  variant?: 'dark' | 'light' | 'white';
}

const {
  heading = 'Ready to Restore Your Smile?',
  subheading = 'Schedule a consultation with Dr. Favian Cheong, your certified prosthodontic specialist in Huntington Beach. We\'ll create a personalized treatment plan just for you.',
  primaryCTA = 'Book Free Consultation',
  primaryHref = site.bookingUrl,
  primaryExternal = true,
  phone = site.phone,
  variant = 'light',
} = Astro.props;

const bgClass = {
  dark: 'bg-charcoal text-white',
  light: 'bg-surface-2 text-charcoal',
  white: 'bg-white text-charcoal border border-border-light',
}[variant];

const headingClass = {
  dark: 'text-white',
  light: 'text-charcoal',
  white: 'text-charcoal',
}[variant];

const subClass = {
  dark: 'text-white/80',
  light: 'text-mid-gray',
  white: 'text-mid-gray',
}[variant];

const phoneClass = {
  dark: 'text-white/80 hover:text-white',
  light: 'text-mid-gray hover:text-charcoal',
  white: 'text-mid-gray hover:text-charcoal',
}[variant];

const useBeachBg = variant === 'light';
---

<section
  class={`relative overflow-hidden rounded-2xl p-8 md:p-12 text-center ${useBeachBg ? 'text-charcoal' : bgClass}`}
  style={useBeachBg ? 'background: linear-gradient(rgba(255,255,255,0.7), rgba(255,255,255,0.7)), url(/images/heroes/beach-abstract-cta.png) center/cover no-repeat' : undefined}
>
  <h2 class={`font-serif text-2xl md:text-3xl font-bold mb-4 ${useBeachBg ? 'text-charcoal' : headingClass}`}>
    {heading}
  </h2>
  <p class={`max-w-2xl mx-auto mb-8 leading-relaxed ${useBeachBg ? 'text-charcoal/90' : subClass}`}>
    {subheading}
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <a href={primaryHref} class={`${variant === 'dark' ? 'btn-secondary border-white text-white hover:bg-white hover:text-charcoal' : useBeachBg ? 'btn-primary' : 'btn-primary'} text-base px-8 py-4 font-semibold rounded-full transition-colors inline-block text-center`} target={primaryExternal ? '_blank' : undefined} rel={primaryExternal ? 'noopener noreferrer' : undefined}>
      {primaryCTA}
    </a>
    <a
      href={`tel:${phone.replace(/\D/g, '')}`}
      class={`font-medium text-base transition-colors ${useBeachBg ? 'text-charcoal hover:text-charcoal/80' : phoneClass}`}
    >
      Or Call: {phone}
    </a>
  </div>
</section>
