---
import { site, address as addr, hours } from '../config/site';
import { serviceCategories } from '../config/services';

const currentYear = new Date().getFullYear();
const phone = site.phone;
const bookHref = site.bookingUrl;
const email = site.email;
const address = addr.street;
const googleReviewLink = site.googleReviewLink;
---

<footer class="bg-white border-t border-border-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- NAP Block -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-4">
          <img src="/images/branding/logo-black.png" alt="Huntington Beach Prosthodontics" class="h-8 w-auto" />
          <div>
            <div class="font-serif text-base font-bold leading-tight text-charcoal">Huntington Beach</div>
            <div class="font-serif text-xs font-semibold text-brand-teal leading-tight">Prosthodontics</div>
          </div>
        </a>
        <address class="not-italic text-charcoal text-sm">
          <div class="space-y-0.5">
            <p>{address}</p>
            <p>Huntington Beach, CA 92649</p>
          </div>
          <div class="mt-3 space-y-1">
            <p>
              <a href={`tel:${phone.replace(/\D/g, '')}`} class="hover:text-charcoal transition-colors font-medium">
                {phone}
              </a>
            </p>
            <p>
              <a href={`mailto:${email}`} class="hover:text-charcoal transition-colors">
                {email}
              </a>
            </p>
          </div>
          <div class="mt-4">
            <p class="text-xs font-semibold text-charcoal uppercase tracking-wide mb-1.5">Hours</p>
            <div class="text-xs space-y-0.5">
              {hours.display.map(h => (
                <p>{h.day}: {h.time}</p>
              ))}
            </div>
          </div>
        </address>
        <div class="mt-4 flex flex-col gap-2">
          <a
            href={googleReviewLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-brand-teal text-sm font-medium hover:text-charcoal transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Leave a Google Review
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61578650704763"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-charcoal text-sm font-medium hover:text-brand-teal transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Follow us on Facebook
          </a>
        </div>
      </div>

      <!-- Services: Dental Implants + Smile Restoration -->
      <div>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">Services</h3>
        {serviceCategories.slice(0, 2).map((cat) => (
          <div class="mb-5 last:mb-0">
            <h4 class="font-serif text-sm font-semibold mb-2 text-charcoal">
              <a href={cat.href} class="hover:text-brand-teal transition-colors">{cat.heading}</a>
            </h4>
            <ul class="space-y-1.5 text-sm text-charcoal">
              {cat.services.map((s) => (
                <li><a href={s.href} class="hover:text-brand-teal transition-colors">{s.name}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Crowns & Dentures + About -->
      <div>
        <div class="mb-5">
          <h4 class="font-serif text-sm font-semibold mb-2 text-charcoal">
            <a href={serviceCategories[2].href} class="hover:text-brand-teal transition-colors">{serviceCategories[2].heading}</a>
          </h4>
          <ul class="space-y-1.5 text-sm text-charcoal">
            {serviceCategories[2].services.map((s) => (
              <li><a href={s.href} class="hover:text-brand-teal transition-colors">{s.name}</a></li>
            ))}
          </ul>
        </div>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">About</h3>
        <ul class="space-y-2 text-sm text-charcoal">
          <li><a href="/about" class="hover:text-brand-teal transition-colors">About Us</a></li>
          <li><a href="/why-a-prosthodontist" class="hover:text-brand-teal transition-colors">Why a Prosthodontist</a></li>
          <li><a href="/financing" class="hover:text-brand-teal transition-colors">Financing</a></li>
          <li><a href="/blog" class="hover:text-brand-teal transition-colors">Blog</a></li>
          <li><a href="/faq" class="hover:text-brand-teal transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">Quick Links</h3>
        <ul class="space-y-2 text-sm text-charcoal">
          <li>
            <a href={bookHref} target="_blank" rel="noopener noreferrer" class="font-medium text-charcoal hover:text-brand-teal transition-colors">
              → Book Appointment
            </a>
          </li>
          <li><a href={`tel:${phone.replace(/\D/g, '')}`} class="hover:text-brand-teal transition-colors">Call {phone}</a></li>
          <li><a href="/dental-implants/consultation" class="hover:text-brand-teal transition-colors">Consultation</a></li>
          <li><a href="/services" class="hover:text-brand-teal transition-colors">All Services</a></li>
          <li><a href="/gallery" class="hover:text-brand-teal transition-colors">Before & After Gallery</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border-light">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-mid-gray">
        <p>© {currentYear} Huntington Beach Prosthodontics. All rights reserved.</p>
        <p class="text-center md:text-right">
          Huntington Beach Prosthodontics is a dental specialty practice. Results may vary.
        </p>
      </div>
    </div>
  </div>
</footer>
