---
import { site, address as addr, hours } from '../config/site';

const currentYear = new Date().getFullYear();
const phone = site.phone;
const email = site.email;
const address = addr.street;
const googleReviewLink = site.googleReviewLink;
---

<footer class="bg-white border-t border-border-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- NAP Block -->
      <div class="lg:col-span-1">
        <div class="font-serif text-xl font-bold mb-1 text-charcoal">Huntington Beach</div>
        <div class="font-serif text-base font-semibold text-brand-teal mb-4">Prosthodontics</div>
        <address class="not-italic text-mid-gray text-sm">
          <div class="space-y-0.5">
            <p>{address}</p>
            <p>Huntington Beach, CA 92649</p>
          </div>
          <div class="mt-3 space-y-1">
            <p>
              <a href={`tel:${phone.replace(/\D/g, '')}`} class="hover:text-charcoal transition-colors font-medium">
                {phone}
              </a>
            </p>
            <p>
              <a href={`mailto:${email}`} class="hover:text-charcoal transition-colors">
                {email}
              </a>
            </p>
          </div>
          <div class="mt-4">
            <p class="text-xs font-semibold text-charcoal uppercase tracking-wide mb-1.5">Hours</p>
            <div class="text-xs space-y-0.5">
              {hours.display.map(h => (
                <p>{h.day}: {h.time}</p>
              ))}
            </div>
          </div>
        </address>
        <div class="mt-4">
          <a
            href={googleReviewLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-brand-teal text-sm font-medium hover:text-charcoal transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Leave a Google Review
          </a>
        </div>
      </div>

      <!-- Treatments -->
      <div>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">Dental Implants</h3>
        <ul class="space-y-2 text-sm text-mid-gray mb-5">
          <li><a href="/dental-implants" class="hover:text-charcoal transition-colors">Dental Implants</a></li>
          <li><a href="/dental-implants/single-tooth" class="hover:text-charcoal transition-colors">Single Tooth Implant</a></li>
          <li><a href="/all-on-x/all-on-4" class="hover:text-charcoal transition-colors">All-on-4 Implants</a></li>
          <li><a href="/all-on-x/all-on-6" class="hover:text-charcoal transition-colors">All-on-6 Implants</a></li>
          <li><a href="/all-on-x/full-arch" class="hover:text-charcoal transition-colors">Full Arch Implants</a></li>
          <li><a href="/dental-implants/bone-grafting" class="hover:text-charcoal transition-colors">Bone Grafting</a></li>
        </ul>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">Smile Restoration</h3>
        <ul class="space-y-2 text-sm text-mid-gray">
          <li><a href="/veneers/porcelain" class="hover:text-charcoal transition-colors">Porcelain Veneers</a></li>
          <li><a href="/veneers/smile-makeover" class="hover:text-charcoal transition-colors">Smile Makeover</a></li>
          <li><a href="/cosmetic-dentistry" class="hover:text-charcoal transition-colors">Cosmetic Dentistry</a></li>
          <li><a href="/clear-aligners" class="hover:text-charcoal transition-colors">Clear Aligners</a></li>
        </ul>
      </div>

      <!-- About & Resources -->
      <div>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">Crowns & Dentures</h3>
        <ul class="space-y-2 text-sm text-mid-gray mb-5">
          <li><a href="/dentures" class="hover:text-charcoal transition-colors">Dentures</a></li>
          <li><a href="/implant-restorations/snap-on" class="hover:text-charcoal transition-colors">Snap-on Dentures</a></li>
          <li><a href="/implant-restorations/crowns" class="hover:text-charcoal transition-colors">Implant Crowns</a></li>
          <li><a href="/implant-restorations/bridges" class="hover:text-charcoal transition-colors">Implant Bridges</a></li>
          <li><a href="/general-dentistry" class="hover:text-charcoal transition-colors">General Dentistry</a></li>
        </ul>
        <h3 class="font-serif text-base font-semibold mb-3 text-charcoal">About & Resources</h3>
        <ul class="space-y-2 text-sm text-mid-gray">
          <li><a href="/services" class="hover:text-charcoal transition-colors">All Services</a></li>
          <li><a href="/about" class="hover:text-charcoal transition-colors">About Us</a></li>
          <li><a href="/blog" class="hover:text-charcoal transition-colors">Patient Blog</a></li>
          <li><a href="/gallery" class="hover:text-charcoal transition-colors">Before & After Gallery</a></li>
          <li><a href="/faq" class="hover:text-charcoal transition-colors">FAQ</a></li>
          <li><a href="/dental-implants/consultation" class="hover:text-charcoal transition-colors">Free Consultation</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-serif text-base font-semibold mb-4 text-charcoal">Quick Links</h3>
        <ul class="space-y-2 text-sm text-mid-gray">
          <li>
            <a href="/schedule" class="font-medium text-charcoal hover:text-brand-navy transition-colors">
              → Book Appointment
            </a>
          </li>
          <li><a href={`tel:${phone.replace(/\D/g, '')}`} class="hover:text-charcoal transition-colors">Call Us: {phone}</a></li>
          <li><a href="/dental-implants/consultation" class="hover:text-charcoal transition-colors">Free Consultation</a></li>
          <li><a href="/faq" class="hover:text-charcoal transition-colors">Patient FAQ</a></li>
          <li><a href="/gallery" class="hover:text-charcoal transition-colors">Before & After Gallery</a></li>
          <li><a href="/about" class="hover:text-charcoal transition-colors">About Our Practice</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border-light">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-mid-gray">
        <p>© {currentYear} Huntington Beach Prosthodontics. All rights reserved.</p>
        <p class="text-center md:text-right">
          Huntington Beach Prosthodontics is a dental specialty practice. Results may vary.
        </p>
      </div>
    </div>
  </div>
</footer>
